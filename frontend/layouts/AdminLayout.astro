---
// AdminLayout.astro
import AdminSidebar from '../src/components/admin/AdminSidebar.astro';
import AdminHeader from '../src/components/admin/AdminHeader.astro';

interface Props {
    title: string;
    subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | CTech Admin</title>
    <link rel="stylesheet" href="/src/styles/globals.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js" is:inline></script>
</head>
<body class="admin-body">
    <div class="admin-container">
        <AdminSidebar />
        <main class="admin-main">
            <AdminHeader title={title} subtitle={subtitle} />
            <div class="admin-content">
                <slot />
            </div>
        </main>
    </div>

    <style is:global>
        :root {
            --primary: #3b82f6;
            --primary-light: rgba(59, 130, 246, 0.1);
            --secondary: #60a5fa;
            --bg-dark: #0F172A; 
            --bg-light: #F8FAFC; 
            --text-main: #1E293B;
            --text-muted: #64748B;
            --glass-bg: rgba(255, 255, 255, 0.7);
            --glass-border: rgba(255, 255, 255, 0.1);
            --card-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
            --sidebar-width: 240px;
        }

        body.admin-body {
            background-color: var(--bg-light);
            margin: 0;
            color: var(--text-main);
            font-family: 'Inter', -apple-system, sans-serif;
            overflow-x: hidden;
        }

        .admin-container {
            display: flex;
            min-height: 100vh;
        }

        .admin-main {
            flex: 1;
            margin-left: var(--sidebar-width); 
            padding: 2rem;
            min-height: 100vh;
            background: var(--bg-light);
            color: var(--text-main);
        }

        /* MINIMALIST UTILITIES */
        .admin-panel {
            background: white;
            border-radius: 12px;
            border: 1px solid #E2E8F0;
            box-shadow: var(--card-shadow);
            overflow: hidden;
            margin-bottom: 2rem;
        }

        .minimal-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.85rem;
        }

        .minimal-table th {
            padding: 0.75rem 1rem;
            text-align: left;
            background: #F8FAFC;
            color: #64748B;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.7rem;
            letter-spacing: 0.025em;
            border-bottom: 1px solid #E2E8F0;
        }

        .minimal-table td {
            padding: 0.75rem 1rem;
            border-bottom: 1px solid #F1F5F9;
            color: #475569;
            vertical-align: middle;
        }

        .minimal-table tr:last-child td {
            border-bottom: none;
        }

        .minimal-table tr:hover {
            background: #F8FAFC;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            padding: 0.2rem 0.5rem;
            border-radius: 4px;
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.02em;
        }

        .badge-success { background: #DCFCE7; color: #15803D; }
        .badge-danger { background: #FEE2E2; color: #B91C1C; }
        .badge-info { background: #DBEAFE; color: #1E40AF; }

        .btn-minimal {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 1rem;
            border-radius: 8px;
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            border: 1px solid #E2E8F0;
            background: white;
            color: #475569;
        }

        .btn-minimal:hover {
            background: #F8FAFC;
            border-color: #CBD5E1;
        }

        .btn-minimal-primary {
            background: #3b82f6;
            color: white;
            border-color: #2563EB;
        }

        .btn-minimal-primary:hover {
            background: #2563EB;
            border-color: #1D4ED8;
        }

        .action-icon-btn {
            width: 28px;
            height: 28px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 6px;
            border: 1px solid #E2E8F0;
            background: white;
            color: #64748B;
            cursor: pointer;
            transition: all 0.2s;
        }

        .action-icon-btn:hover {
            background: #F1F5F9;
            color: #0F172A;
        }

        .action-icon-btn svg {
            width: 14px;
            height: 14px;
        }

        /* MODALS MINIMALIST */
        .modal-backdrop {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, 0.5);
            backdrop-filter: blur(4px);
            z-index: 9999;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }

        .modal-backdrop.open {
            display: flex;
        }

        .modal-minimal {
            background: white;
            border-radius: 12px;
            width: 100%;
            max-width: 500px;
            box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);
            overflow: hidden;
            border: 1px solid #E2E8F0;
        }

        .modal-header-minimal {
            padding: 1rem 1.5rem;
            border-bottom: 1px solid #F1F5F9;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .modal-header-minimal h3 {
            margin: 0;
            font-size: 1rem;
            font-weight: 700;
            color: #0F172A;
        }

        .modal-body-minimal {
            padding: 1.5rem;
        }

        .modal-footer-minimal {
            padding: 1rem 1.5rem;
            background: #F8FAFC;
            border-top: 1px solid #F1F5F9;
            display: flex;
            justify-content: flex-end;
            gap: 0.75rem;
        }

        /* FORM GROUPS MINIMAL */
        .form-group-minimal {
            margin-bottom: 1rem;
        }

        .form-group-minimal label {
            display: block;
            font-size: 0.75rem;
            font-weight: 600;
            color: #64748B;
            text-transform: uppercase;
            letter-spacing: 0.025em;
            margin-bottom: 0.25rem;
        }

        .form-group-minimal input, 
        .form-group-minimal select, 
        .form-group-minimal textarea {
            width: 100%;
            padding: 0.5rem 0.75rem;
            border-radius: 6px;
            border: 1px solid #E2E8F0;
            font-size: 0.9rem;
            color: #1E293B;
            outline: none;
            transition: border-color 0.2s;
        }

        .form-group-minimal input:focus, 
        .form-group-minimal select:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.1);
        }

        .admin-content {
            margin-top: 1rem;
        }
    </style>
</body>
</html>
