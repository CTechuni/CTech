---
// LeaderLayout.astro
import LeaderSidebar from '../components/leader/LeaderSidebar.astro';
import LeaderHeader from '../components/leader/LeaderHeader.astro';

interface Props {
    title: string;
    subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Leader Hub</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="/styles/global.css" />
</head>
<body class="leader-body">
    <div class="leader-container">
        <LeaderSidebar />
        <main class="leader-main">
            <LeaderHeader title={title} subtitle={subtitle} />
            <div class="leader-content">
                <slot />
            </div>
        </main>
    </div>

    <style is:global>
        :root {
            --leader-primary: #10b981;
            --leader-secondary: #059669;
            --bg-dark: #020617; /* Even darker for leader */
            --glass-bg: rgba(255, 255, 255, 0.02);
            --glass-border: rgba(255, 255, 255, 0.08);
        }

        body.leader-body {
            background-color: var(--bg-dark);
            background-image: 
                radial-gradient(at 0% 0%, rgba(16, 185, 129, 0.07) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(5, 150, 105, 0.05) 0px, transparent 50%);
            margin: 0;
            color: white;
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
            min-height: 100vh;
        }

        .leader-container {
            display: flex;
            min-height: 100vh;
        }

        .leader-main {
            flex: 1;
            margin-left: 280px;
            padding: 3rem 4rem;
            position: relative;
        }

        .leader-content {
            margin-top: 1.5rem;
            animation: slideUp 0.7s cubic-bezier(0.16, 1, 0.3, 1);
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Responsive */
        @media (max-width: 1024px) {
            .leader-main { margin-left: 0; padding: 2rem; }
            .leader-sidebar { transform: translateX(-100%); transition: transform 0.4s ease; }
            .leader-sidebar.open { transform: translateX(0); }
        }
    </style>
</body>
</html>
