---
import AdminLayout from '../../layouts/AdminLayout.astro';

const title = 'Ajustes';
const subtitle = 'Configuración de la plataforma';
---

<AdminLayout title={title} subtitle={subtitle}>
  <div class="settings-page">
    <div class="settings-nav glass-morphism">
      <nav class="settings-menu">
        <a href="#general" class="active">General</a>
        <a href="#notifications">Notificaciones</a>
        <a href="#appearance">Apariencia</a>
        <a href="#api">API & Integraciones</a>
        <a href="#backup">Copias de Seguridad</a>
      </nav>
    </div>

    <div class="settings-content">
      <section id="general" class="settings-section glass-morphism">
        <header class="section-header">
          <h2>Configuración General</h2>
          <p>Ajustes básicos del sitio y la organización</p>
        </header>

        <form class="settings-form">
          <div class="form-group">
            <label>Nombre del Sitio</label>
            <input type="text" value="CTech Platform" />
          </div>
          <div class="form-group">
            <label>Descripción Meta</label>
            <textarea rows="3">Comunidad tecnológica líder en networking y aprendizaje colaborativo.</textarea>
          </div>
          <div class="form-group">
            <label>Email de Contacto</label>
            <input type="email" value="contacto@ctech.com" />
          </div>

          <div class="toggle-group">
            <div class="toggle-info">
              <h4>Mantenimiento</h4>
              <p>Activa el modo mantenimiento para ocultar el sitio a usuarios.</p>
            </div>
            <label class="switch">
              <input type="checkbox">
              <span class="slider round"></span>
            </label>
          </div>

          <div class="form-actions">
            <button type="submit" class="btn-primary">Guardar Cambios</button>
          </div>
        </form>
      </section>

      <section id="appearance" class="settings-section glass-morphism">
        <header class="section-header">
          <h2>Marca y Personalización</h2>
          <p>Controla los colores y logos de la plataforma</p>
        </header>
        
        <div class="appearance-grid">
          <div class="color-picker-item">
            <label>Color Primario</label>
            <div class="color-swatch" style="background: #0073ff;"></div>
            <span>#0073ff</span>
          </div>
          <div class="color-picker-item">
            <label>Color Accent</label>
            <div class="color-swatch" style="background: #f97316;"></div>
            <span>#f97316</span>
          </div>
        </div>
      </section>
    </div>
  </div>

  <style>
    .settings-page {
      display: grid;
      grid-template-columns: 240px 1fr;
      gap: 2rem;
    }

    .glass-morphism {
      background: white;
      border-radius: 20px;
      border: 1px solid #e2e8f0;
      box-shadow: var(--card-shadow);
      padding: 1.5rem;
    }

    .settings-menu {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .settings-menu a {
      padding: 0.75rem 1rem;
      border-radius: 8px;
      color: #64748b;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.9rem;
      transition: all 0.2s;
    }

    .settings-menu a:hover {
      background: #f8fafc;
      color: #0f172a;
    }

    .settings-menu a.active {
      background: #eff6ff;
      color: #0073ff;
    }

    .settings-content {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    .section-header {
      margin-bottom: 2rem;
      border-bottom: 1px solid #f1f5f9;
      padding-bottom: 1.5rem;
    }

    .section-header h2 {
      font-size: 1.25rem;
      font-weight: 800;
      margin: 0;
      color: #0f172a;
    }

    .section-header p {
      margin: 0.25rem 0 0;
      font-size: 0.9rem;
      color: #64748b;
    }

    .settings-form {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .form-group label {
      font-size: 0.85rem;
      font-weight: 700;
      color: #1e293b;
    }

    .form-group input, .form-group textarea {
      padding: 0.85rem;
      border-radius: 12px;
      border: 1px solid #e2e8f0;
      font-size: 0.95rem;
      outline: none;
      transition: border-color 0.2s;
    }

    .form-group input:focus { border-color: #0073ff; }

    .toggle-group {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.5rem;
      background: #f8fafc;
      border-radius: 16px;
    }

    .toggle-info h4 { margin: 0; font-size: 0.95rem; }
    .toggle-info p { margin: 0.2rem 0 0; font-size: 0.85rem; color: #64748b; }

    .btn-primary {
      background: #0073ff;
      color: white;
      border: none;
      padding: 0.85rem 2rem;
      border-radius: 12px;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 4px 12px rgba(0, 115, 255, 0.2);
    }

    /* Switch Style */
    .switch { position: relative; display: inline-block; width: 44px; height: 24px; }
    .switch input { opacity: 0; width: 0; height: 0; }
    .slider { position: absolute; cursor: pointer; inset: 0; background-color: #cbd5e1; transition: .4s; border-radius: 24px; }
    .slider:before { position: absolute; content: ""; height: 18px; width: 18px; left: 3px; bottom: 3px; background-color: white; transition: .4s; border-radius: 50%; }
    input:checked + .slider { background-color: #0073ff; }
    input:checked + .slider:before { transform: translateX(20px); }

    .appearance-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 2rem;
    }

    .color-picker-item {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      align-items: center;
    }

    .color-swatch {
      width: 100%;
      height: 60px;
      border-radius: 12px;
      border: 4px solid #f1f5f9;
    }

    @media (max-width: 768px) {
      .settings-page { grid-template-columns: 1fr; }
    }
  </style>
</AdminLayout>
