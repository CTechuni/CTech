---
// src/pages/admin/index.astro - Dashboard Rediseñado
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Dashboard" subtitle="Global">

<div class="dashboard-wrap">
    <!-- TOP STAT CARDS -->
<div class="metrics-grid-minimal">
    <div class="metric-card-minimal">
        <div class="metric-icon-minimal users-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" /></svg>
        </div>
        <div class="metric-info-minimal">
            <span class="metric-label">Total Usuarios</span>
            <div class="metric-value-row">
                <h3 id="totalUsers">519</h3>
                <span class="trend-up">+12%</span>
            </div>
        </div>
    </div>

    <div class="metric-card-minimal">
        <div class="metric-icon-minimal communities-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0a5.995 5.995 0 0 0-4.058-3.042M6 18.719a5.971 5.971 0 0 1 .941-3.197m0 0a5.995 5.995 0 0 1 4.058-3.042m0 0a5.991 5.991 0 0 1 2.102-.376m0 0a5.991 5.991 0 0 0-2.102-.376M12 9c1.657 0 3-1.343 3-3s-1.343-3-3-3-3 1.343-3 3 1.343 3 3 3Zm7.5 7.5a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0ZM6 16.5a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" /></svg>
        </div>
        <div class="metric-info-minimal">
            <span class="metric-label">Comunidades</span>
            <div class="metric-value-row">
                <h3 id="totalCommunities">6</h3>
                <span class="trend-up">+1</span>
            </div>
        </div>
    </div>

    <div class="metric-card-minimal">
        <div class="metric-icon-minimal courses-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18c-2.305 0-4.408.867-6 2.292m0-14.25v14.25" /></svg>
        </div>
        <div class="metric-info-minimal">
            <span class="metric-label">Cursos Activos</span>
            <div class="metric-value-row">
                <h3 id="totalCourses">6</h3>
                <span class="trend-up">+3</span>
            </div>
        </div>
    </div>

    <div class="metric-card-minimal">
        <div class="metric-icon-minimal events-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" /></svg>
        </div>
        <div class="metric-info-minimal">
            <span class="metric-label">Eventos del Mes</span>
            <div class="metric-value-row">
                <h3 id="totalEvents">6</h3>
                <span class="trend-up">+5</span>
            </div>
        </div>
    </div>
</div>

    <!-- MAIN CHARTS ROW -->
    <div class="charts-grid mt-4">
        <!-- USER GROWTH CHART -->
        <div class="chart-card large-chart">
            <div class="chart-header">
                <div class="ch-text">
                    <h4>Crecimiento de Usuarios</h4>
                    <span class="subtitle">Últimos 7 meses</span>
                </div>
                <div class="ch-trend positive">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3 h-3"><path fill-rule="evenodd" d="M11.47 2.47a.75.75 0 0 1 1.06 0l7.5 7.5a.75.75 0 1 1-1.06 1.06l-6.22-6.22V21a.75.75 0 0 1-1.5 0V4.81l-6.22 6.22a.75.75 0 1 1-1.06-1.06l7.5-7.5Z" clip-rule="evenodd" /></svg> +8.2%
                </div>
            </div>
            <div class="chart-container">
                <canvas id="userGrowthChart"></canvas>
            </div>
        </div>

        <!-- ROLE DISTRIBUTION CHART -->
        <div class="chart-card small-chart">
            <div class="chart-header">
                <div class="ch-text">
                    <h4>Distribución de Roles</h4>
                    <span class="subtitle">Composición de usuarios</span>
                </div>
            </div>
            <div class="chart-container pie-container">
                <canvas id="roleDistChart"></canvas>
            </div>
            <div class="chart-legend" id="roleLegend">
                <!-- Dinámico -->
            </div>
        </div>
    </div>

    <!-- BOTTOM ROW -->
    <div class="charts-grid mt-4">
        <!-- MEMBERS BY COMMUNITY -->
        <div class="chart-card medium-chart">
            <div class="chart-header">
                <div class="ch-text">
                    <h4>Miembros por Comunidad</h4>
                    <span class="subtitle">Total de registrados</span>
                </div>
            </div>
            <div class="chart-container">
                <canvas id="commMembersChart"></canvas>
            </div>
        </div>

        <!-- UPCOMING EVENTS LIST -->
        <div class="chart-card medium-chart events-panel">
            <div class="chart-header">
                <div class="ch-text">
                    <h4>Próximos Eventos</h4>
                </div>
            </div>
            <div class="upcoming-events-list">
                <div class="event-item">
                    <div class="event-date">
                        <span class="day">4</span>
                        <span class="month">MAR</span>
                    </div>
                    <div class="event-info">
                        <strong>Meetup DevFront #12</strong>
                        <span>DevFront Colombia - 7:00 PM</span>
                    </div>
                    <span class="event-type online">online</span>
                </div>

                <div class="event-item">
                    <div class="event-date">
                        <span class="day">9</span>
                        <span class="month">MAR</span>
                    </div>
                    <div class="event-info">
                        <strong>Hackathon DataScience</strong>
                        <span>DataScience Hub - 9:00 AM</span>
                    </div>
                    <span class="event-type presencial">presencial</span>
                </div>

                <div class="event-item">
                    <div class="event-date">
                        <span class="day">13</span>
                        <span class="month">MAR</span>
                    </div>
                    <div class="event-info">
                        <strong>Workshop Docker</strong>
                        <span>DevOps Cloud - 6:00 PM</span>
                    </div>
                    <span class="event-type online">online</span>
                </div>

                <div class="event-item">
                    <div class="event-date">
                        <span class="day">17</span>
                        <span class="month">MAR</span>
                    </div>
                    <div class="event-info">
                        <strong>UX Research Talk</strong>
                        <span>UX/UI Design - 5:30 PM</span>
                    </div>
                    <span class="event-type online">online</span>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .dashboard-wrap { display: flex; flex-direction: column; gap: 1.5rem; padding-bottom: 2rem; }

    /* METRICS MINIMAL */
    .metrics-grid-minimal { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
    .metric-card-minimal { background: #FFFFFF; border: 1px solid #F1F5F9; border-radius: 12px; padding: 1.25rem; display: flex; align-items: center; gap: 1rem; transition: transform 0.2s; }
    .metric-card-minimal:hover { transform: translateY(-2px); border-color: #E2E8F0; }
    
    .metric-icon-minimal { width: 44px; height: 44px; border-radius: 10px; display: flex; align-items: center; justify-content: center; background: #F8FAFC; color: #64748B; }
    .metric-icon-minimal svg { width: 22px; height: 22px; }
    
    .metric-info-minimal { flex: 1; }
    .metric-label { font-size: 0.75rem; font-weight: 600; color: #94A3B8; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.25rem; display: block; }
    .metric-value-row { display: flex; align-items: baseline; gap: 0.75rem; }
    .metric-value-row h3 { margin: 0; font-size: 1.5rem; font-weight: 700; color: #0F172A; }
    .trend-up { font-size: 0.75rem; font-weight: 700; color: #10B981; }

    /* Colors */
    .users-icon { background: #EFF6FF; color: #3B82F6; }
    .communities-icon { background: #F0FDF4; color: #22C55E; }
    .courses-icon { background: #F5F3FF; color: #8B5CF6; }
    .events-icon { background: #FFF7ED; color: #F59E0B; }

    /* CHARTS MINIMAL */
    .charts-grid { display: grid; grid-template-columns: 2fr 1.2fr; gap: 1.25rem; margin-top: 1rem; }
    .chart-card { background: #FFFFFF; border: 1px solid #F1F5F9; border-radius: 16px; padding: 1.5rem; display: flex; flex-direction: column; }
    .chart-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.5rem; }
    .ch-text h4 { margin: 0; font-size: 1rem; font-weight: 700; color: #0F172A; }
    .ch-text .subtitle { font-size: 0.8rem; color: #94A3B8; }
    
    .chart-container { min-height: 240px; position: relative; }
    
    /* UPCOMING EVENTS */
    .upcoming-events-list { display: flex; flex-direction: column; gap: 1rem; }
    .event-item { display: flex; align-items: center; gap: 1rem; padding: 0.75rem 0; border-bottom: 1px solid #F8FAFC; }
    .event-item:last-child { border-bottom: none; }
    .event-date { width: 42px; height: 42px; background: #F1F5F9; border-radius: 8px; display: flex; flex-direction: column; align-items: center; justify-content: center; }
    .event-date .day { font-size: 0.9rem; font-weight: 800; color: #0F172A; line-height: 1; }
    .event-date .month { font-size: 0.6rem; font-weight: 700; color: #64748B; text-transform: uppercase; }
    .event-info { flex: 1; }
    .event-info strong { display: block; font-size: 0.9rem; color: #0F172A; margin-bottom: 2px; }
    .event-info span { font-size: 0.75rem; color: #64748B; }
    
    @media (max-width: 1024px) {
        .metrics-grid-minimal { grid-template-columns: repeat(2, 1fr); }
        .charts-grid { grid-template-columns: 1fr; }
    }
</style>

<script>
    // Autenticación deshabilitada en desarrollo: solo usamos utilidades de API
    import { AuthManager } from '../../utils/auth.js';

    // Stats fetching (opcional, no bloquea la vista si falla)
    async function loadStats() {
        try {
            const data = await AuthManager.fetch('/metrics/admin');
            if (data) {
                if (document.getElementById('totalUsers')) document.getElementById('totalUsers').textContent = data.total_users || '0';
                if (document.getElementById('totalCommunities')) document.getElementById('totalCommunities').textContent = data.total_communities || '0';
                if (document.getElementById('totalCourses')) document.getElementById('totalCourses').textContent = data.total_courses || '0';
            }
        } catch (e) { console.error('Error fetching admin metrics:', e); }
    }

    function initCharts() {
        // @ts-ignore
        const ChartLib = window.Chart;
        if (!ChartLib) return;

        // 1. Line Chart: Growth
        const growthCtx = document.getElementById('userGrowthChart') as HTMLCanvasElement;
        new ChartLib(growthCtx, {
            type: 'line',
            data: {
                labels: ['Sep', 'Oct', 'Nov', 'Dic', 'Ene', 'Feb', 'Mar'],
                datasets: [{
                    label: 'Usuarios',
                    data: [120, 180, 250, 290, 410, 520, 519],
                    borderColor: '#3b82f6',
                    backgroundColor: 'rgba(59, 130, 246, 0.05)',
                    fill: true,
                    tension: 0.4,
                    borderWidth: 2,
                    pointRadius: 0,
                    pointHoverRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { display: false }, ticks: { color: '#94a3b8', font: { size: 11 } } },
                    y: { 
                        beginAtZero: true, 
                        grid: { color: '#f1f5f9' },
                        ticks: { color: '#94a3b8', font: { size: 11 }, stepSize: 200 }
                    }
                }
            }
        });

        // 2. Doughnut Chart: Roles
        const roleCtx = document.getElementById('roleDistChart') as HTMLCanvasElement;
        new ChartLib(roleCtx, {
            type: 'doughnut',
            data: {
                labels: ['Usuarios', 'Mentores', 'Líderes'],
                datasets: [{
                    data: [6, 2, 6],
                    backgroundColor: ['#3b82f6', '#8b5cf6', '#f59e0b'],
                    borderWidth: 4,
                    borderColor: '#ffffff',
                    hoverOffset: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                cutout: '80%'
            }
        });

        // 3. Bar Chart: Communities
        const commCtx = document.getElementById('commMembersChart') as HTMLCanvasElement;
        new ChartLib(commCtx, {
            type: 'bar',
            data: {
                labels: ['DevFront', 'Backend', 'Data', 'Mobile', 'DevOps', 'UX/UI'],
                datasets: [{
                    data: [142, 98, 75, 61, 54, 89],
                    backgroundColor: '#3b82f6',
                    borderRadius: 6,
                    barThickness: 16
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { display: false }, ticks: { color: '#94a3b8', font: { size: 11 } } },
                    y: { grid: { color: '#f1f5f9' }, ticks: { color: '#94a3b8', font: { size: 11 } } }
                }
            }
        });
    }

    loadStats();
    // Wait for CDN if needed
    if (window.Chart) {
        initCharts();
    } else {
        document.addEventListener('DOMContentLoaded', initCharts);
    }
</script>

</AdminLayout>

