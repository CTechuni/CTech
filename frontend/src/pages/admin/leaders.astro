---
import AdminLayout from '../../layouts/AdminLayout.astro';
import AdminUsersSection from '../../components/admin/AdminUsersSection.astro';

const title = 'Líderes';
const subtitle = 'Gestión de líderes de comunidad';
---

<AdminLayout title={title} subtitle={subtitle}>
  <section class="admin-page-section">
    <header class="admin-page-header">
      <p class="page-kicker">Panel Admin</p>
      <h2 class="page-title">Directorio de Líderes</h2>
      <p class="page-subtitle">Gestiona a los líderes encargados de las comunidades locales</p>
    </header>

    <!-- Usamos AdminUsersSection y añadiremos un script para filtrar por líder por defecto -->
    <AdminUsersSection />
  </section>

  <style>
    .admin-page-section {
      display: flex;
      flex-direction: column;
      gap: 1.75rem;
    }

    .admin-page-header {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .page-kicker {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #94a3b8;
      margin: 0;
      font-weight: 600;
    }

    .page-title {
      margin: 0;
      font-size: 1.4rem;
      font-weight: 800;
      color: #0f172a;
    }

    .page-subtitle {
      margin: 0;
      font-size: 0.9rem;
      color: #94a3b8;
    }
  </style>

  <script>
    // Forzar el filtro de "Líderes" al cargar la página
    window.addEventListener('DOMContentLoaded', () => {
      const roleFilter = document.getElementById('roleFilter') as HTMLSelectElement;
      if (roleFilter) {
        roleFilter.value = 'leader';
        // Disparamos el evento change para que AdminUsersSection reaccione
        roleFilter.dispatchEvent(new Event('change'));
      }
    });
  </script>
</AdminLayout>
