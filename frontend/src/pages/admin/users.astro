---
// src/pages/admin/users.astro
import AdminLayout from '../../layouts/AdminLayout.astro'
// import AdminLayout from '../Layout/AdminLayout.astro';
---

<AdminLayout title="Usuarios" subtitle="Todos los usuarios registrados en la plataforma">

<div class="page-header-minimal">
    <div class="header-text-minimal">
        <h2>Directorio de Usuarios</h2>
        <p style="color:#64748B; font-size:0.85rem">Gestiona los miembros de la plataforma</p>
    </div>
    <div class="header-actions-minimal">
        <div class="minimal-search">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" /></svg>
            <input type="text" id="searchInput" placeholder="Buscar usuario..." />
        </div>
    </div>
</div>

<div class="admin-panel">
    <div class="table-wrap">
        <table class="minimal-table">
            <thead>
                <tr>
                    <th style="width: 50px;"></th>
                    <th>Nombre</th>
                    <th>Correo</th>
                    <th>Rol</th>
                    <th>Comunidad</th>
                    <th>Estado</th>
                    <th>Registro</th>
                    <th style="width: 100px;">Acciones</th>
                </tr>
            </thead>
            <tbody id="usersBody">
                <tr><td colspan="8" class="loading-row">Cargando usuarios...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Promote Modal -->
<div class="modal-backdrop" id="promoteModal">
    <div class="modal-minimal" style="max-width: 400px;">
        <div class="modal-header-minimal">
            <h3>Promover a Mentor</h3>
            <button class="modal-close-btn" data-close="promoteModal" style="font-size:1.2rem">&times;</button>
        </div>
        <div class="modal-body-minimal">
            <p style="color:#475569; margin:0 0 1rem; font-size:0.9rem;">¿Deseas promover a <strong id="promoteName" style="color:#0F172A"></strong> a Mentor?</p>
            <div class="form-group-minimal">
                <label>Especialidad</label>
                <select id="specialtySelect">
                    <option value="">-- Seleccionar especialidad --</option>
                </select>
            </div>
        </div>
        <div class="modal-footer-minimal">
            <button class="btn-minimal" data-close="promoteModal">Cancelar</button>
            <button class="btn-minimal btn-minimal-primary" id="confirmPromote">Confirmar Ascenso</button>
        </div>
    </div>
</div>

<style>
    .page-header-minimal { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2rem; }
    .header-text-minimal h2 { margin:0; font-size: 1.25rem; font-weight: 700; color: #0F172A; }
    
    .minimal-search { position: relative; width: 280px; }
    .minimal-search svg { position: absolute; left: 0.75rem; top: 50%; transform: translateY(-50%); width:14px; height:14px; color: #94A3B8; }
    .minimal-search input { width: 100%; padding: 0.5rem 0.75rem 0.5rem 2.2rem; background: white; border: 1px solid #E2E8F0; border-radius: 8px; color: #1E293B; font-size: 0.85rem; outline: none; transition: border-color .2s; }
    .minimal-search input:focus { border-color: #3b82f6; }

    .user-avatar-small { width: 28px; height: 28px; border-radius: 6px; object-fit: cover; border: 1px solid #F1F5F9; }
    .loading-row { text-align: center; padding: 3rem !important; color: #94A3B8; font-style: italic; }

    .modal-close-btn { background: transparent; border: none; cursor: pointer; color: #94A3B8; padding: 4px; border-radius: 4px; display: flex; align-items: center; justify-content: center; }
    .modal-close-btn:hover { background: #F1F5F9; color: #0F172A; }
</style>

<script>
import { AuthManager } from '../../utils/auth.js';

let allUsers = [];
let pendingPromoteId = null;

async function loadUsers() {
    try {
        const data = await AuthManager.fetch('/users/');
        allUsers = Array.isArray(data) ? data : [];
        renderTable(allUsers);
    } catch(e) { console.error(e); }
}

async function loadSpecialties() {
    try {
        const data = await AuthManager.fetch('/specialties/');
        const sel = document.getElementById('specialtySelect');
        (Array.isArray(data) ? data : []).forEach(s => {
            sel.innerHTML += `<option value="${s.id}">${s.name}</option>`;
        });
    } catch(e) { console.warn('Specialties not loaded'); }
}

function renderTable(list) {
    const tbody = document.getElementById('usersBody');
    if (!list.length) { tbody.innerHTML = '<tr><td colspan="8" class="loading-row">Sin usuarios registrados</td></tr>'; return; }
    tbody.innerHTML = list.map(u => {
        const role = (u.role || 'user').toLowerCase();
        const isAdmin = role === 'admin' || u.id === 1;
        const isUser  = role === 'user';
        const isActive = (u.status || 'active') === 'active';
        const date = u.registration_date ? new Date(u.registration_date).toLocaleDateString() : '-';
        
        const promoteBtn = isUser
            ? `<button class="action-icon-btn" onclick="openPromote(${u.id},'${(u.name_user||'').replace(/'/g,"\\'")}')\" title="Promover a mentor"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5 12 3m0 0 7.5 7.5M12 3v18" /></svg></button>`
            : `<button class="action-icon-btn" disabled style="opacity:0.25"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5 12 3m0 0 7.5 7.5M12 3v18" /></svg></button>`;
        
        const deleteBtn = !isAdmin
            ? `<button class="action-icon-btn" onclick="deleteUser(${u.id})" title="Eliminar" style="color:#ef4444; border-color:#fee2e2;"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" /></svg></button>`
            : '';

        const avatarUrl = u.photo_url || `https://api.dicebear.com/7.x/avataaars/svg?seed=${encodeURIComponent(u.name_user || 'user')}`;
        
        let roleBadgeClass = 'badge-info';
        if (role === 'admin') roleBadgeClass = 'badge-danger';
        if (role === 'mentor') roleBadgeClass = 'badge-success';
        if (role === 'leader') roleBadgeClass = 'badge-success';

        return `<tr>
            <td><img src="${avatarUrl}" alt="Avatar" class="user-avatar-small" /></td>
            <td><span style="font-weight: 600; color: #0F172A;">${u.name_user || '-'}</span></td>
            <td><span style="font-size:0.8rem; color:#64748B">${u.email || '-'}</span></td>
            <td><span class="badge ${roleBadgeClass}">${role}</span></td>
            <td style="font-size:0.85rem">${u.community_name || '—'}</td>
            <td><span class="badge ${isActive ? 'badge-success' : 'badge-danger'}">${isActive ? 'Activo' : 'Inactivo'}</span></td>
            <td style="font-size:0.8rem; color:#94A3B8">${date}</td>
            <td><div style="display:flex; gap:0.5rem">${promoteBtn}${deleteBtn}</div></td>
        </tr>`;
    }).join('');
}

document.getElementById('searchInput')?.addEventListener('input', function() {
    const q = this.value.toLowerCase();
    renderTable(allUsers.filter(u =>
        (u.name_user||'').toLowerCase().includes(q) ||
        (u.email||'').toLowerCase().includes(q) ||
        (u.community_name||'').toLowerCase().includes(q)
    ));
});

function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
document.querySelectorAll('[data-close]').forEach(btn => btn.addEventListener('click', () => closeModal(btn.dataset.close)));
document.querySelectorAll('.modal-backdrop').forEach(m => m.addEventListener('click', e => { if (e.target === m) m.classList.remove('open'); }));

window.openPromote = function(id, name) {
    pendingPromoteId = id;
    document.getElementById('promoteName').textContent = name;
    openModal('promoteModal');
};

document.getElementById('confirmPromote')?.addEventListener('click', async () => {
    const specialtyId = document.getElementById('specialtySelect').value;
    if (!pendingPromoteId || !specialtyId) { alert('Selecciona una especialidad.'); return; }
    try {
        await AuthManager.fetch(`/users/${pendingPromoteId}/promote`, { method: 'POST', body: JSON.stringify({ specialty_id: parseInt(specialtyId) }) });
        closeModal('promoteModal');
        loadUsers();
    } catch(e) { alert('Error: ' + e.message); }
});

window.deleteUser = async function(id) {
    if (!confirm('¿Eliminar este usuario? Esta acción no se puede deshacer.')) return;
    try { await AuthManager.fetch(`/users/${id}`, { method: 'DELETE' }); loadUsers(); }
    catch(e) { alert('Error: ' + e.message); }
};

loadUsers();
loadSpecialties();
</script>

</AdminLayout>
