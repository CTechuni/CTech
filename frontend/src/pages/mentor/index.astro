---
// src/pages/mentor/index.astro
import MentorLayout from '../../layouts/MentorLayout.astro';
---

<MentorLayout title="Panel de Mentor" subtitle="Bienvenido de nuevo a tu portal de mentoría.">
    <div class="dashboard-grid">
        <!-- Stat Cards -->
        <div class="stat-card glass-morphic">
            <div class="icon-box purple"><i class="fas fa-book-reader"></i></div>
            <div class="stat-info">
                <h3>4</h3>
                <p>Cursos Activos</p>
            </div>
        </div>
        <div class="stat-card glass-morphic">
            <div class="icon-box blue"><i class="fas fa-video"></i></div>
            <div class="stat-info">
                <h3>12</h3>
                <p>Sesiones este Mes</p>
            </div>
        </div>
        <div class="stat-card glass-morphic">
            <div class="icon-box gold"><i class="fas fa-star"></i></div>
            <div class="stat-info">
                <h3>4.9</h3>
                <p>Calificación Promedio</p>
            </div>
        </div>
        <div class="stat-card glass-morphic">
            <div class="icon-box green"><i class="fas fa-user-graduate"></i></div>
            <div class="stat-info">
                <h3>156</h3>
                <p>Estudiantes Totales</p>
            </div>
        </div>
    </div>

    <div class="sessions-preview glass-morphic">
        <div class="section-header">
            <h2>Próximas Sesiones</h2>
            <a href="/mentor/sessions" class="view-all">Ver todas</a>
        </div>
        <div class="session-list">
            <!-- Mock Sessions -->
            <div class="session-item">
                <div class="session-time">14:00 - 15:30</div>
                <div class="session-details">
                    <h4>Introducción a React Hooks</h4>
                    <p>Curso: Frontend Avanzado</p>
                </div>
                <button class="join-btn">Unirse</button>
            </div>
            <div class="session-item">
                <div class="session-time">16:00 - 17:00</div>
                <div class="session-details">
                    <h4>Q&A Arquitectura Microservicios</h4>
                    <p>Curso: Node.js Enterprise</p>
                </div>
                <button class="join-btn secondary">Preparar</button>
            </div>
        </div>
    </div>

    <style>
        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .glass-morphic {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 20px;
            padding: 1.5rem;
        }

        .stat-card {
            display: flex;
            align-items: center;
            gap: 1.2rem;
            transition: transform 0.3s ease;
        }

        .stat-card:hover { transform: translateY(-5px); }

        .icon-box {
            width: 50px;
            height: 50px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
        }

        .purple { background: rgba(139, 92, 246, 0.2); color: #a78bfa; }
        .blue { background: rgba(59, 130, 246, 0.2); color: #60a5fa; }
        .gold { background: rgba(245, 158, 11, 0.2); color: #fbbf24; }
        .green { background: rgba(16, 185, 129, 0.2); color: #34d399; }

        .stat-info h3 { font-size: 1.8rem; margin: 0; font-weight: 800; }
        .stat-info p { margin: 0; font-size: 0.9rem; color: rgba(255, 255, 255, 0.5); }

        .sessions-preview {
            margin-top: 2rem;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }

        .section-header h2 { font-size: 1.5rem; margin: 0; }
        .view-all { color: #a78bfa; text-decoration: none; font-size: 0.9rem; font-weight: 600; }

        .session-list { display: flex; flex-direction: column; gap: 1rem; }

        .session-item {
            display: flex;
            align-items: center;
            gap: 2rem;
            padding: 1rem;
            background: rgba(255, 255, 255, 0.02);
            border-radius: 15px;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .session-time {
            font-weight: 700;
            color: #a78bfa;
            min-width: 120px;
        }

        .session-details h4 { margin: 0; font-size: 1.1rem; }
        .session-details p { margin: 0.2rem 0 0; font-size: 0.85rem; color: rgba(255, 255, 255, 0.5); }

        .join-btn {
            margin-left: auto;
            background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
            border: none;
            color: white;
            padding: 0.6rem 1.5rem;
            border-radius: 10px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .join-btn:hover { box-shadow: 0 0 20px rgba(139, 92, 246, 0.4); transform: scale(1.05); }
        .join-btn.secondary { background: rgba(255, 255, 255, 0.1); }
    </style>

    <script>
        /* ⚠️ BYPASS TEMPORAL - SOLO SIMULACRO VISUAL. Reactivar antes de producción.
        import { authManager, requireRole } from '../../utils/auth.js';
        
        // Proteger la vista
        if (!requireRole('mentor')) {
            // Redirigirá automáticamente si falla
        }

        const auth = authManager;
        const user = auth.getUser();
        */
        console.info('[BYPASS VISUAL] mentor/index.astro: guard de auth deshabilitado temporalmente.');
    </script>
</MentorLayout>

