---
import MainLayout from "../../layouts/MainLayout.astro";
import { escapeHtml } from '../../utils/escape.js';
const title = "Cursos";
---

<MainLayout title={title}>
    <div class="user-courses-container" id="userCoursesContainer">
        <p>Cargando cursos...</p>
    </div>
</MainLayout>

<style>
.user-courses-container {
    max-width: 1000px;
    margin: 2rem auto;
    padding: 0 1rem;
    display: grid;
    grid-template-columns: repeat(auto-fit,minmax(280px,1fr));
    gap: 1.5rem;
}
.course-card {
    background: white;
    border-radius: 12px;
    border: 1px solid var(--color-light-grey);
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    box-shadow: 0 2px 6px rgba(0,0,0,0.05);
}
.course-card h3 {
    font-size: 1.1rem;
    margin: 0;
}
.course-card .progress-btn {
    margin-top: auto;
}
</style>

<script>
    import { authManager } from '../../utils/auth.js';

    let allCourses = [];

    document.addEventListener('DOMContentLoaded', async () => {
        const user = authManager.getUser();
        if (!user) return;
        try {
            const courses = await authManager.get('courses');
            allCourses = courses || [];
            const communityId = user.community_id;
            const filtered = allCourses.filter(c => c.community_id == communityId);
            renderCourses(filtered);
        } catch (err) {
            console.error('Error loading courses for user:', err);
            const c = document.getElementById('userCoursesContainer');
            if (c) c.innerHTML = '<p>Error cargando cursos.</p>';
        }
    });

    function getProgressMap() {
        try {
            return JSON.parse(localStorage.getItem('courseProgress') || '{}');
        } catch {
            return {};
        }
    }
    function setProgressMap(map) {
        localStorage.setItem('courseProgress', JSON.stringify(map));
    }

    function renderCourses(courses) {
        const container = document.getElementById('userCoursesContainer');
        if (!container) return;
        if (courses.length === 0) {
            container.innerHTML = '<p>No hay cursos disponibles para tu comunidad.</p>';
            return;
        }
        const prog = getProgressMap();
        container.innerHTML = '';
        courses.forEach(c => {
            const card = document.createElement('div');
            card.className = 'course-card';
            const progress = prog[c.id_course] || 0;
            card.innerHTML = `
                <h3>${escapeHtml(c.title)}</h3>
                <p>${escapeHtml(c.description || '')}</p>
                <button class="btn progress-btn">${progress ? 'Continuar curso' : 'Iniciar curso'}</button>
            `;
            const btn = card.querySelector('button.progress-btn');
            if (btn) {
                btn.addEventListener('click', () => toggleProgress(c.id_course));
            }
            container.appendChild(card);
        });
    }

    function toggleProgress(courseId) {
        const map = getProgressMap();
        if (!map[courseId]) {
            map[courseId] = { started: Date.now(), progress: 0 };
        }
        // For demonstration we simply toggle removal
        else {
            delete map[courseId];
        }
        setProgressMap(map);
        const user = authManager.getUser();
        const communityId = user.community_id;
        const filtered = allCourses.filter(c => c.community_id == communityId);
        renderCourses(filtered);
    }
</script>