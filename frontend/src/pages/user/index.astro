---
// src/pages/user/index.astro
import UserLayout from '../../layouts/UserLayout.astro';
---

<UserLayout title="Hola, Usuario" subtitle="¡Qué bueno verte de nuevo! Continúa tu aprendizaje hoy.">
    <div class="dashboard-grid">
        <div class="stat-card glass-morphic">
            <div class="icon-box amber"><i class="fas fa-graduation-cap"></i></div>
            <div class="stat-info">
                <h3>3</h3>
                <p>Cursos en Progreso</p>
            </div>
        </div>
        <div class="stat-card glass-morphic">
            <div class="icon-box orange"><i class="fas fa-calendar-star"></i></div>
            <div class="stat-info">
                <h3>2</h3>
                <p>Eventos Próximos</p>
            </div>
        </div>
        <div class="stat-card glass-morphic">
            <div class="icon-box yellow"><i class="fas fa-clock"></i></div>
            <div class="stat-info">
                <h3>42h</h3>
                <p>Tiempo de Estudio</p>
            </div>
        </div>
        <div class="stat-card glass-morphic">
            <div class="icon-box rose"><i class="fas fa-fire"></i></div>
            <div class="stat-info">
                <h3>15</h3>
                <p>Días de Racha</p>
            </div>
        </div>
    </div>

    <div class="user-sections">
        <div class="recommended-courses glass-morphic">
            <div class="section-header">
                <h2>Cursos Recomendados</h2>
                <a href="/user/courses" class="link-btn">Explorar todo</a>
            </div>
            <div class="course-mini-grid">
                <div class="course-card-mini">
                    <img src="https://images.unsplash.com/photo-1633356122544-f134324a6cee?w=400&q=80" alt="react" />
                    <div class="mini-info">
                        <h4>Mastering React 18</h4>
                        <div class="progress-bar"><div class="fill" style="width: 65%"></div></div>
                        <span>65% completado</span>
                    </div>
                </div>
                <div class="course-card-mini">
                    <img src="https://images.unsplash.com/photo-1587620962725-abab7fe55159?w=400&q=80" alt="python" />
                    <div class="mini-info">
                        <h4>Python para Data Science</h4>
                        <div class="progress-bar"><div class="fill" style="width: 15%"></div></div>
                        <span>15% completado</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="upcoming-events glass-morphic">
            <h2>Próximos Eventos</h2>
            <div class="event-mini-list">
                <div class="event-card-mini">
                    <div class="event-date-box">
                        <span class="day">15</span>
                        <span class="month">MAR</span>
                    </div>
                    <div class="event-mini-details">
                        <h5>Hackathon Global CTech</h5>
                        <p><i class="fas fa-map-marker-alt"></i> Online</p>
                    </div>
                </div>
                <div class="event-card-mini">
                    <div class="event-date-box">
                        <span class="day">22</span>
                        <span class="month">MAR</span>
                    </div>
                    <div class="event-mini-details">
                        <h5>Charla: IA en el Trabajo</h5>
                        <p><i class="fas fa-map-marker-alt"></i> Auditorio A</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 1.5rem;
            margin-bottom: 3rem;
        }

        .glass-morphic {
            background: rgba(255, 255, 255, 0.02);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 28px;
            padding: 2rem;
        }

        .stat-card {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .stat-card:hover { transform: translateY(-10px) rotate(1deg); border-color: rgba(245, 158, 11, 0.3); }

        .icon-box {
            width: 60px;
            height: 60px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.6rem;
        }

        .amber { background: rgba(245, 158, 11, 0.15); color: #f59e0b; }
        .orange { background: rgba(249, 115, 22, 0.15); color: #fb923c; }
        .yellow { background: rgba(234, 179, 8, 0.15); color: #facc15; }
        .rose { background: rgba(244, 63, 94, 0.15); color: #fb7185; }

        .stat-info h3 { font-size: 2.2rem; margin: 0; font-weight: 900; }
        .stat-info p { margin: 0.1rem 0 0; font-size: 0.95rem; color: rgba(255, 255, 255, 0.4); font-weight: 600; }

        .user-sections {
            display: grid;
            grid-template-columns: 1.5fr 1fr;
            gap: 2rem;
        }

        .section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
        .section-header h2 { font-size: 1.6rem; margin: 0; font-weight: 800; }
        .link-btn { color: #f59e0b; text-decoration: none; font-weight: 700; font-size: 0.95rem; }

        .course-mini-grid { display: flex; flex-direction: column; gap: 1.2rem; }

        .course-card-mini {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            padding: 1rem;
            background: rgba(255, 255, 255, 0.01);
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.04);
            transition: all 0.3s ease;
        }

        .course-card-mini:hover { background: rgba(255, 255, 255, 0.03); transform: translateX(5px); }

        .course-card-mini img { width: 80px; height: 80px; border-radius: 12px; object-fit: cover; }

        .mini-info { flex: 1; }
        .mini-info h4 { margin: 0 0 0.8rem; font-size: 1.1rem; color: white; }

        .progress-bar { width: 100%; height: 6px; background: rgba(255, 255, 255, 0.05); border-radius: 3px; overflow: hidden; margin-bottom: 0.4rem; }
        .fill { height: 100%; background: linear-gradient(90deg, #f59e0b, #fbbf24); border-radius: 3px; }
        .mini-info span { font-size: 0.8rem; color: rgba(255, 255, 255, 0.4); }

        .upcoming-events h2 { font-size: 1.6rem; margin-bottom: 2rem; font-weight: 800; }
        .event-mini-list { display: flex; flex-direction: column; gap: 1rem; }

        .event-card-mini {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            padding: 1.2rem;
            background: rgba(245, 158, 11, 0.03);
            border-radius: 22px;
            border-left: 4px solid #f59e0b;
        }

        .event-date-box {
            display: flex;
            flex-direction: column;
            align-items: center;
            background: rgba(245, 158, 11, 0.1);
            padding: 0.5rem 0.8rem;
            border-radius: 12px;
            min-width: 60px;
        }

        .event-date-box .day { font-size: 1.3rem; font-weight: 900; color: white; }
        .event-date-box .month { font-size: 0.75rem; font-weight: 800; color: #f59e0b; }

        .event-mini-details h5 { margin: 0; font-size: 1.05rem; color: white; }
        .event-mini-details p { margin: 0.3rem 0 0; font-size: 0.85rem; color: rgba(255, 255, 255, 0.5); }
        .event-mini-details i { margin-right: 0.4rem; color: #f59e0b; }

        @media (max-width: 1200px) {
            .user-sections { grid-template-columns: 1fr; }
        }
    </style>
</UserLayout>

<script>
    import { AuthManager, requireAuth } from '../../utils/auth.js';
    
    // Proteger la vista
    if (!requireAuth()) {
        // Redirige automáticamente se encarga requireAuth
    }

    const auth = authManager;
    const user = auth.getUser();
</script>

