---
// src/pages/leader/index.astro
import LeaderLayout from '../../layouts/LeaderLayout.astro';
---

<LeaderLayout title="Panel de Líder" subtitle="Gestiona y haz crecer tu comunidad tecnológica.">
    <div class="dashboard-grid">
        <div class="stat-card glass-morphic">
            <div class="icon-box emerald"><i class="fas fa-users"></i></div>
            <div class="stat-info">
                <h3>1,240</h3>
                <p>Miembros en Comunidad</p>
            </div>
        </div>
        <div class="stat-card glass-morphic">
            <div class="icon-box mint"><i class="fas fa-calendar-check"></i></div>
            <div class="stat-info">
                <h3>8</h3>
                <p>Eventos este Mes</p>
            </div>
        </div>
        <div class="stat-card glass-morphic">
            <div class="icon-box teal"><i class="fas fa-chart-line"></i></div>
            <div class="stat-info">
                <h3>24%</h3>
                <p>Crecimiento Mensual</p>
            </div>
        </div>
        <div class="stat-card glass-morphic">
            <div class="icon-box lime"><i class="fas fa-medal"></i></div>
            <div class="stat-info">
                <h3>#3</h3>
                <p>Ranking Global</p>
            </div>
        </div>
    </div>

    <div class="community-overview">
        <div class="activity-feed glass-morphic">
            <div class="section-header">
                <h2>Actividad de la Comunidad</h2>
                <button class="icon-btn"><i class="fas fa-ellipsis-h"></i></button>
            </div>
            <div class="feed-items">
                <div class="feed-item">
                    <div class="user-avatar-small">
                        <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=user1" alt="avatar" />
                    </div>
                    <div class="feed-content">
                        <strong>Juan Perez</strong> se unió a la comunidad.
                        <span>Hace 5 minutos</span>
                    </div>
                </div>
                <div class="feed-item">
                    <div class="user-avatar-small">
                        <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=user2" alt="avatar" />
                    </div>
                    <div class="feed-content">
                        <strong>Maria Gomez</strong> publicó un nuevo recurso en el canal #react.
                        <span>Hace 2 horas</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="quick-actions glass-morphic">
            <h2>Acciones Rápidas</h2>
            <div class="action-buttons">
                <button class="action-btn"><i class="fas fa-plus"></i> Crear Evento</button>
                <button class="action-btn"><i class="fas fa-bullhorn"></i> Enviar Anuncio</button>
                <button class="action-btn"><i class="fas fa-user-plus"></i> Invitar Miembros</button>
                <button class="action-btn secondary"><i class="fas fa-file-export"></i> Exportar Datos</button>
            </div>
        </div>
    </div>

    <style>
        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2.5rem;
        }

        .glass-morphic {
            background: rgba(255, 255, 255, 0.02);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 24px;
            padding: 1.8rem;
        }

        .stat-card {
            display: flex;
            align-items: center;
            gap: 1.2rem;
            transition: all 0.3s ease;
        }

        .stat-card:hover { transform: translateY(-8px); border-color: rgba(16, 185, 129, 0.3); }

        .icon-box {
            width: 55px;
            height: 55px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
        }

        .emerald { background: rgba(16, 185, 129, 0.15); color: #34d399; }
        .mint { background: rgba(52, 211, 153, 0.15); color: #6ee7b7; }
        .teal { background: rgba(20, 184, 166, 0.15); color: #5eead4; }
        .lime { background: rgba(132, 204, 22, 0.15); color: #bef264; }

        .stat-info h3 { font-size: 2rem; margin: 0; font-weight: 900; letter-spacing: -0.02em; }
        .stat-info p { margin: 0.1rem 0 0; font-size: 0.9rem; color: rgba(255, 255, 255, 0.5); font-weight: 500; }

        .community-overview {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 2rem;
        }

        .section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
        .section-header h2 { font-size: 1.4rem; margin: 0; }
        
        .activity-feed h2, .quick-actions h2 { font-size: 1.4rem; margin-bottom: 1.5rem; }

        .feed-items { display: flex; flex-direction: column; gap: 1.2rem; }

        .feed-item {
            display: flex;
            align-items: center;
            gap: 1.2rem;
            padding: 1rem;
            background: rgba(255, 255, 255, 0.01);
            border-radius: 16px;
            transition: background 0.3s ease;
        }

        .feed-item:hover { background: rgba(255, 255, 255, 0.03); }

        .user-avatar-small img { width: 36px; height: 36px; border-radius: 10px; }

        .feed-content { flex: 1; font-size: 0.95rem; line-height: 1.4; color: rgba(255, 255, 255, 0.7); }
        .feed-content strong { color: white; font-weight: 600; }
        .feed-content span { display: block; font-size: 0.8rem; color: rgba(255, 255, 255, 0.3); margin-top: 0.2rem; }

        .action-buttons { display: flex; flex-direction: column; gap: 1rem; }

        .action-btn {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            border: none;
            color: white;
            padding: 0.9rem 1.4rem;
            border-radius: 14px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .action-btn:hover { box-shadow: 0 10px 20px rgba(16, 185, 129, 0.2); transform: scale(1.02); }
        .action-btn.secondary { background: rgba(255, 255, 255, 0.05); color: rgba(255, 255, 255, 0.8); border: 1px solid rgba(255, 255, 255, 0.1); }
        .action-btn.secondary:hover { background: rgba(255, 255, 255, 0.08); }

        @media (max-width: 1200px) {
            .community-overview { grid-template-columns: 1fr; }
        }
    </style>
</LeaderLayout>

<script>
    import { authManager, requireRole } from '../../utils/auth.js';
    // Proteger la vista
    if (!requireRole('leader')) {
        // Redirige automáticamente se encarga requireRole
    }

    const auth = authManager;
    const user = auth.getUser();
</script>

