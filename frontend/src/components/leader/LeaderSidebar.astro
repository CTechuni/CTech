---
// LeaderSidebar.astro
const menuItems = [
    { icon: 'fas fa-tachometer-alt', label: 'Dashboard', path: '/leader' },
    { icon: 'fas fa-users-cog', label: 'Mi Comunidad', path: '/leader/community' },
    { icon: 'fas fa-user-friends', label: 'Miembros', path: '/leader/members' },
    { icon: 'fas fa-calendar-day', label: 'Eventos', path: '/leader/events' },
    { icon: 'fas fa-user-circle', label: 'Perfil', path: '/leader/profile' },
];
---

<aside class="leader-sidebar">
    <div class="sidebar-logo">
        <img src="/logo-ctech.png" alt="CTech" />
        <span>Leader Hub</span>
    </div>

    <div class="profile-card">
        <div class="avatar-circle">LM</div>
        <div class="profile-info">
            <span class="profile-name">Laura Méndez</span>
            <span class="profile-badge">Líder</span>
        </div>
    </div>

    <nav class="sidebar-nav">
        {menuItems.map(item => (
            <a href={item.path} class="nav-item">
                <i class={item.icon}></i>
                <span>{item.label}</span>
            </a>
        ))}
    </nav>

    <div class="sidebar-footer">
        <button id="logoutBtn" class="nav-item logout">
            <i class="fas fa-sign-out-alt"></i>
            <span>Cerrar Sesión</span>
        </button>
    </div>
</aside>

<style>
    .leader-sidebar {
        width: 260px;
        height: 100vh;
        position: fixed;
        left: 0;
        top: 0;
        background-color: var(--color-primary-dark);
        display: flex;
        flex-direction: column;
        padding: 2rem 1.2rem;
        z-index: 1000;
        box-shadow: 4px 0 15px rgba(0, 0, 0, 0.1);
    }

    .sidebar-logo {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        margin-bottom: 2.5rem;
        padding-left: 0.5rem;
    }

    .sidebar-logo img { width: 32px; }
    .sidebar-logo span { 
        font-weight: 700; 
        font-size: 1.1rem;
        color: white;
    }

    /* Profile Card Implementation */
    .profile-card {
        background-color: var(--color-primary);
        border-radius: 12px;
        padding: 1rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .avatar-circle {
        width: 40px;
        height: 40px;
        background-color: #E0F2FE; /* Light blue */
        color: var(--color-primary);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.9rem;
        flex-shrink: 0;
    }

    .profile-info {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
    }

    .profile-name {
        color: white;
        font-weight: 600;
        font-size: 0.9rem;
        white-space: nowrap;
    }

    .profile-badge {
        background-color: var(--color-azure-radiant);
        color: white;
        font-size: 0.7rem;
        padding: 0.1rem 0.5rem;
        border-radius: 4px;
        font-weight: 700;
        width: fit-content;
    }

    .sidebar-nav { flex: 1; }

    .nav-item {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        padding: 0.8rem 1rem;
        color: var(--color-blue-grey);
        text-decoration: none;
        border-radius: 8px;
        margin-bottom: 0.5rem;
        transition: all 0.2s ease;
        font-weight: 500;
        font-size: 0.95rem;
    }

    .nav-item:hover {
        color: white;
        background: rgba(255, 255, 255, 0.05);
    }

    .nav-item.active {
        background-color: var(--color-azure-radiant);
        color: white;
    }

    .nav-item i { width: 20px; text-align: center; }

    .logout {
        width: 100%;
        background: transparent;
        border: none;
        cursor: pointer;
        color: var(--color-blue-grey) !important;
        justify-content: flex-start;
    }
    
    .logout:hover {
        color: #ef4444 !important;
        background: rgba(239, 68, 68, 0.1);
    }
</style>

<script>
    /* ⚠️ BYPASS TEMPORAL - SOLO SIMULACRO VISUAL. Reactivar antes de producción.
    import { AuthManager, authManager } from "../../utils/auth.js";

    document.getElementById('logoutBtn')?.addEventListener('click', () => {
        const auth = authManager;
        auth.logout();
        window.location.href = '/login';
    });
    */

    // Logout estático para simulacro
    document.getElementById('logoutBtn')?.addEventListener('click', () => {
        console.info('[BYPASS VISUAL] Logout deshabilitado durante simulacro.');
        window.location.href = '/';
    });

    // Mark active link and persist ID
    const currentPath = window.location.pathname;
    const urlParams = new URLSearchParams(window.location.search);
    const userId = urlParams.get('id');

    document.querySelectorAll('.nav-item').forEach(link => {
        // Persistir ID en los enlaces si existe
        if (userId && link.tagName === 'A') {
            const href = link.getAttribute('href');
            if (href && !href.startsWith('http') && !href.includes('id=')) {
                link.setAttribute('href', `${href}${href.includes('?') ? '&' : '?'}id=${userId}`);
            }
        }

        if (link.getAttribute('href')?.split('?')[0] === currentPath) {
            link.classList.add('active');
        }
    });
</script>

