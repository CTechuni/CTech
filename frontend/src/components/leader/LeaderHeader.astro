---
// LeaderHeader.astro
interface Props {
    title: string;
    subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<header class="leader-header">
    <div class="header-info">
        <h1>{title}</h1>
    </div>

    <div class="header-actions">
        <div class="notification-box">
            <i class="fas fa-bell"></i>
            <span class="notification-badge">3</span>
        </div>
        <div class="user-avatar-mini">LM</div>
    </div>
</header>

<style>
    .leader-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background-color: white;
        padding: 1rem 2rem;
        margin: -2rem -3rem 2rem -3rem; /* Offset the main padding */
        border-bottom: 1px solid var(--color-light-grey);
    }

    .header-info h1 {
        font-size: 1.25rem;
        font-weight: 700;
        margin: 0;
        color: var(--color-primary-dark);
    }

    .header-actions {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .notification-box {
        position: relative;
        font-size: 1.2rem;
        color: var(--color-blue-grey);
        cursor: pointer;
    }

    .notification-badge {
        position: absolute;
        top: -5px;
        right: -5px;
        background-color: var(--color-azure-radiant);
        color: white;
        font-size: 0.65rem;
        padding: 0.1rem 0.35rem;
        border-radius: 50%;
        font-weight: 700;
        border: 2px solid white;
    }

    .user-avatar-mini {
        width: 35px;
        height: 35px;
        background-color: var(--color-primary);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 0.8rem;
    }
</style>

