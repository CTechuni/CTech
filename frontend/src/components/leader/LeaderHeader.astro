---
// LeaderHeader.astro
interface Props {
    title: string;
    subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<header class="leader-header">
    <div class="header-info">
        <h1>{title}</h1>
        {subtitle && <p class="subtitle">{subtitle}</p>}
    </div>

    <div class="header-actions">
        <div class="community-badge">
            <i class="fas fa-shield-alt"></i>
            <span id="communityName">Mi Comunidad</span>
        </div>
        <div class="user-profile">
            <div class="user-info">
                <span id="userName">Líder Name</span>
                <span class="role-tag">Líder de Comunidad</span>
            </div>
            <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=leader" alt="avatar" />
        </div>
    </div>
</header>

<style>
    .leader-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2.5rem;
        padding: 1rem 0;
    }

    .header-info h1 {
        font-size: 2.3rem;
        font-weight: 800;
        margin: 0;
        background: linear-gradient(135deg, #fff 0%, #34d399 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        letter-spacing: -0.03em;
    }

    .subtitle {
        color: rgba(255, 255, 255, 0.45);
        margin: 0.4rem 0 0;
        font-size: 1.05rem;
        font-weight: 400;
    }

    .header-actions {
        display: flex;
        align-items: center;
        gap: 2.5rem;
    }

    .community-badge {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        color: #34d399;
        font-weight: 600;
        background: rgba(52, 211, 153, 0.1);
        padding: 0.5rem 1rem;
        border-radius: 12px;
        border: 1px solid rgba(52, 211, 153, 0.2);
    }

    .user-profile {
        display: flex;
        align-items: center;
        gap: 1.1rem;
        background: rgba(255, 255, 255, 0.04);
        padding: 0.7rem 1.3rem;
        border-radius: 18px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        transition: all 0.4s ease;
    }

    .user-profile:hover {
        background: rgba(255, 255, 255, 0.07);
        border-color: rgba(52, 211, 153, 0.4);
        transform: translateY(-2px);
    }

    .user-info {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
    }

    .user-info #userName { font-weight: 700; font-size: 1rem; color: white; }
    .role-tag { font-size: 0.7rem; color: #34d399; font-weight: 800; text-transform: uppercase; letter-spacing: 0.08em; }

    .user-profile img {
        width: 44px;
        height: 44px;
        border-radius: 14px;
        border: 2px solid rgba(52, 211, 153, 0.2);
    }
</style>

<script>
    import { authManager } from '../../utils/auth';
    const auth = authManager;
    const user = auth.getUser();
    if (user) {
        document.getElementById('userName').textContent = user.name_user || user.name;
        // Mock community name if not present
        if (user.community_name) {
            document.getElementById('communityName').textContent = user.community_name;
        }
    }
</script>

