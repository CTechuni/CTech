---

<aside class="admin-sidebar">
    <div class="sidebar-brand">
        <a href="/admin" class="brand-link" aria-label="CTech Admin">
            <img src="/LogoCTech.svg" alt="CTech" class="brand-logo" />
        </a>
        <p class="brand-subtitle">gestión administrativa</p>
    </div>

    <div class="user-profile-widget">
        <div class="profile-card">
            <div class="profile-avatar" id="sideAvatarContainer">
                <span id="userInitial">CR</span>
            </div>
            <div class="profile-info">
                <span class="profile-name" id="userNameSide">Carlos Ramírez</span>
                <span class="profile-location">Global</span>
            </div>
            <span class="role-tag">Administrador</span>
            <button class="expand-btn">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M16.28 11.47a.75.75 0 0 1 0 1.06l-7.5 7.5a.75.75 0 0 1-1.06-1.06L14.69 12 7.72 5.03a.75.75 0 0 1 1.06-1.06l7.5 7.5z" clip-rule="evenodd" /></svg>
            </button>
        </div>
    </div>

    <nav class="sidebar-nav">
        {menuItems.map(item => (
            <a href={item.path} class="nav-item" data-path={item.path}>
                <Fragment set:html={item.icon} />
                <span>{item.label}</span>
            </a>
        ))}
    </nav>

    <div class="sidebar-footer">
        <button id="logoutBtn" class="logout-btn">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path fill-rule="evenodd" d="M7.5 3.75A1.5 1.5 0 0 0 6 5.25v13.5a1.5 1.5 0 0 0 1.5 1.5h6a1.5 1.5 0 0 0 1.5-1.5V15a.75.75 0 0 1 1.5 0v3.75a3 3 0 0 1-3 3h-6a3 3 0 0 1-3-3V5.25a3 3 0 0 1 3-3h6a3 3 0 0 1 3 3V9A.75.75 0 0 1 15 9V5.25a1.5 1.5 0 0 0-1.5-1.5h-6Zm10.72 4.72a.75.75 0 0 1 1.06 0l3 3a.75.75 0 0 1 0 1.06l-3 3a.75.75 0 1 1-1.06-1.06l1.72-1.72H9a.75.75 0 0 1 0-1.5h10.94l-1.72-1.72a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" /></svg>
            <span>Salir</span>
        </button>
    </div>
</aside>

<style>
    .admin-sidebar {
        width: var(--sidebar-width);
        height: 100vh;
        position: fixed;
        left: 0;
        top: 0;
        background: #0F172A;
        display: flex;
        flex-direction: column;
        padding: 0;
        z-index: 1000;
        color: white;
        border-right: 1px solid rgba(255, 255, 255, 0.05);
    }

    .sidebar-brand {
        padding: 1.25rem 1rem 0.75rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .brand-link {
        display: block;
        margin-bottom: 0.5rem;
    }

    .brand-logo {
        height: 32px;
        width: auto;
        display: block;
    }

    .brand-subtitle {
        margin: 0;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: rgba(255, 255, 255, 0.5);
    }

    /* USER PROFILE WIDGET */
    .user-profile-widget {
        padding: 1rem 1rem;
    }

    .profile-card {
        background: rgba(255, 255, 255, 0.03);
        border-radius: 12px;
        padding: 0.75rem 1rem;
        position: relative;
        display: grid;
        grid-template-columns: 32px 1fr;
        gap: 0.75rem;
        align-items: center;
    }

    .profile-avatar {
        width: 32px;
        height: 32px;
        background: #3b82f6;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1.1rem;
        border: 2px solid rgba(255,255,255,0.1);
        overflow: hidden;
    }
    .profile-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .profile-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .profile-name {
        font-size: 0.85rem;
        font-weight: 600;
    }

    .profile-location {
        display: none;
    }

    .role-tag {
        grid-column: 1 / -1;
        margin-top: 0.25rem;
        background: rgba(59, 130, 246, 0.1);
        color: #60a5fa;
        font-size: 0.65rem;
        font-weight: 600;
        padding: 0.15rem 0.5rem;
        border-radius: 4px;
        width: fit-content;
        text-transform: uppercase;
        letter-spacing: 0.02em;
    }

    .expand-btn {
        position: absolute;
        right: -10px;
        top: 50%;
        transform: translateY(-50%);
        width: 20px;
        height: 20px;
        background: #0073ff;
        border: none;
        border-radius: 50%;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        cursor: pointer;
        box-shadow: 0 4px 10px rgba(0, 115, 255, 0.3);
    }

    .sidebar-nav {
        flex: 1;
        padding: 0.5rem 0.75rem;
        display: flex;
        flex-direction: column;
        gap: 0.1rem;
        overflow-y: auto; /* Allow scroll only if absolutely necessary, but hidden scrollbar below */
        scrollbar-width: none; /* Firefox */
    }
    .sidebar-nav::-webkit-scrollbar { display: none; } /* Chrome/Safari */

    .nav-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.5rem 0.75rem;
        color: rgba(255, 255, 255, 0.4);
        text-decoration: none;
        border-radius: 8px;
        font-size: 0.82rem;
        font-weight: 500;
        transition: all 0.2s ease;
    }

    .nav-item :global(svg) {
        width: 14px !important;
        height: 14px !important;
        min-width: 14px;
        min-height: 14px;
        flex-shrink: 0;
    }

    .nav-item:hover {
        color: white;
        background: rgba(255,255,255,0.03);
    }

    .nav-item.active {
        background: rgba(59, 130, 246, 0.1);
        color: #60a5fa;
        font-weight: 600;
    }

    .sidebar-footer {
        padding: 1rem 0.75rem;
        border-top: 1px solid rgba(255,255,255,0.05);
    }

    .logout-btn {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        width: 100%;
        padding: 0.5rem 0.75rem;
        background: transparent;
        border: none;
        color: rgba(255, 255, 255, 0.4);
        cursor: pointer;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 500;
        transition: all 0.2s ease;
    }

    .logout-btn svg {
        width: 16px;
        height: 16px;
        flex-shrink: 0;
    }

    .logout-btn:hover {
        background: rgba(255, 255, 255, 0.05);
        color: white;
    }
</style>

<script>
    /* ⚠️ BYPASS TEMPORAL - SOLO SIMULACRO VISUAL. Reactivar antes de producción.
    import { AuthManager, authManager } from "../../utils/auth.js";
    const auth = authManager;

    // Fill user info
    const user = auth.getUser();
    if (user) {
        if (document.getElementById('userNameSide')) document.getElementById('userNameSide').textContent = user.name_user || 'Admin';
        
        const avatarContainer = document.getElementById('sideAvatarContainer');
        const photoUrl = user.photo_url || `https://api.dicebear.com/7.x/avataaars/svg?seed=${encodeURIComponent(user.name_user || 'admin')}&backgroundColor=b6e3f4`;
        
        if (avatarContainer) {
            avatarContainer.innerHTML = `<img src="${photoUrl}" alt="Avatar" />`;
        }
    }

    document.getElementById('logoutBtn')?.addEventListener('click', () => {
        auth.logout();
        window.location.href = '/';
    });
    */

    // Datos estáticos durante simulacro
    console.info('[BYPASS VISUAL] AdminSidebar: usando datos estáticos Carlos Ramírez.');

    // Logout estático para simulacro
    document.getElementById('logoutBtn')?.addEventListener('click', () => {
        console.info('[BYPASS VISUAL] Logout deshabilitado durante simulacro.');
        window.location.href = '/';
    });

    // Mark active nav item
    const currentPath = window.location.pathname;
    document.querySelectorAll('.nav-item').forEach(link => {
        const linkPath = link.getAttribute('data-path');
        if (linkPath && (currentPath === linkPath || (linkPath !== '/admin' && currentPath.startsWith(linkPath)))) {
            link.classList.add('active');
        } else if (linkPath === '/admin' && currentPath === '/admin') {
            link.classList.add('active');
        }
    });
</script>

