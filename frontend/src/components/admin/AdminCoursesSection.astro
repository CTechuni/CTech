---
/* AdminCoursesSection.astro */
---

<div class="admin-courses-section">
    <div class="section-top-header">
        <div class="header-text">
            <h2>Cursos</h2>
            <p id="coursesTotalCount">0 cursos en la plataforma</p>
        </div>
        <div class="header-actions">
            <button class="btn-secondary-action" id="openToolsBtn">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path fill-rule="evenodd" d="M11.078 2.25c-.917 0-1.699.663-1.85 1.567L9.05 4.889c-.02.12-.115.26-.297.348a7.493 7.493 0 0 0-.986.57c-.166.115-.334.11-.45.021l-.933-.717a1.875 1.875 0 0 0-2.524.232L3.33 6.415a1.875 1.875 0 0 0 .232 2.524l.933.717c.115.088.13.227.05.393a7.447 7.447 0 0 0-.57.986c-.088.182-.228.277-.348.297l-1.072.18c-.904.151-1.567.933-1.567 1.85v1.078c0 .917.663 1.699 1.567 1.85l1.072.18c.12.02.26.115.348.297.18.34.373.67.57.986.08.166.065.305-.05.393l-.933.717a1.875 1.875 0 0 0-.232 2.524l1.078 1.078a1.875 1.875 0 0 0 2.524-.232l.933-.717c.115-.088.254-.083.393-.05.34.18.67.373.986.57.182.088.277.228.297.348l.18 1.072c.151.904.933 1.567 1.85 1.567h1.078c.917 0 1.699-.663 1.85-1.567l.18-1.072c.02-.12.115-.26.297-.348a7.485 7.485 0 0 0 .986-.57c.166-.115.305-.115.421-.05l.933.717a1.875 1.875 0 0 0 2.524-.232l1.078-1.078a1.875 1.875 0 0 0-.232-2.524l-.933-.717c-.08-.061-.09-.2-.05-.393a7.44 7.44 0 0 0 .57-.986c.088-.182.228-.277.348-.297l1.072-.18c.904-.151 1.567-.933 1.567-1.85v-1.078c0-.917-.663-1.699-1.567-1.85l-1.072-.18c-.12-.02-.26-.115-.348-.297a7.49 7.49 0 0 0-.57-.986c-.088-.166-.088-.305.05-.393l.933-.717a1.875 1.875 0 0 0 .232-2.524l-1.078-1.078a1.875 1.875 0 0 0-2.524.232l-.933.717c-.115.088-.227.08-.393.05a7.493 7.493 0 0 0-.986-.57c-.182-.088-.277-.228-.297-.348l-.18-1.072c-.151-.904-.933-1.567-1.85-1.567h-1.078ZM12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" clip-rule="evenodd" /></svg> Utilidades
            </button>
            <button class="btn-add-course" id="addCourseBtn">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path fill-rule="evenodd" d="M12 3.75a.75.75 0 0 1 .75.75v6.75h6.75a.75.75 0 0 1 0 1.5h-6.75v6.75a.75.75 0 0 1-1.5 0v-6.75H4.5a.75.75 0 0 1 0-1.5h6.75V4.5a.75.75 0 0 1 .75-.75z" clip-rule="evenodd" /></svg> Crear Programa
            </button>
        </div>
    </div>

    <div class="filter-bar">
        <div class="search-input-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 search-icon"><path fill-rule="evenodd" d="M10.5 3.75a6.75 6.75 0 1 0 0 13.5 6.75 6.75 0 0 0 0-13.5zM2.25 10.5a8.25 8.25 0 1 1 14.59 5.28l4.69 4.69a.75.75 0 1 1-1.06 1.06l-4.69-4.69A8.25 8.25 0 0 1 2.25 10.5z" clip-rule="evenodd" /></svg>
            <input type="text" placeholder="Buscar por título, tecnología o especialidad..." id="courseSearch">
        </div>
        <div class="quick-filters">
            <button class="q-filter active">Todos</button>
            <button class="q-filter">Premium</button>
            <button class="q-filter">Gratuitos</button>
        </div>
    </div>

    <div class="courses-grid-premium" id="coursesGrid">
        <div class="loading-state">
            <div class="spinner"></div>
            <span>Organizando currículo académico...</span>
        </div>
    </div>
</div>

<!-- Modal Structure Simplificada para UI -->
<div class="modal-backdrop" id="courseModal">
    <div class="modal-card">
        <h3>Gestionar Programa</h3>
        <p>Editor de cursos, módulos y recursos didácticos.</p>
        <button class="btn-close-modal" id="closeCourseModal">Volver al panel</button>
    </div>
</div>

<style>
    .admin-courses-section {
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .section-top-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .header-text h2 {
        font-size: 1.5rem;
        font-weight: 800;
        color: #1E293B;
        margin: 0;
    }

    .header-text p {
        font-size: 0.9rem;
        color: #94A3B8;
        margin: 0.2rem 0 0 0;
        font-weight: 500;
    }

    .header-actions { display: flex; gap: 1rem; }

    .btn-add-course {
        background: #0073ff;
        color: white;
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 12px;
        font-weight: 700;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        cursor: pointer;
        box-shadow: 0 4px 12px rgba(0, 115, 255, 0.2);
    }

    .btn-secondary-action {
        background: white;
        color: #64748B;
        border: 1px solid #E2E8F0;
        padding: 0.75rem 1.25rem;
        border-radius: 12px;
        font-weight: 700;
        font-size: 0.9rem;
        cursor: pointer;
    }

    /* FILTERS */
    .filter-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 2rem;
    }

    .search-input-wrap {
        position: relative;
        flex: 1;
        max-width: 450px;
    }

    .search-icon {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: #94A3B8;
    }

    .search-input-wrap input {
        width: 100%;
        padding: 0.85rem 1rem 0.85rem 2.8rem;
        border-radius: 12px;
        border: 1px solid #E2E8F0;
        background: white;
        font-size: 0.9rem;
        outline: none;
    }

    .quick-filters { display: flex; gap: 0.5rem; }
    .q-filter {
        padding: 0.5rem 1rem;
        border-radius: 10px;
        border: 1px solid #E2E8F0;
        background: white;
        color: #64748B;
        font-weight: 600;
        font-size: 0.85rem;
        cursor: pointer;
    }
    .q-filter.active { background: #F1F5F9; color: #0073ff; border-color: #0073ff; }

    /* GRID */
    .courses-grid-premium {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
        gap: 1.5rem;
    }

    /* COURSE CARD */
    .course-card-premium {
        background: white;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: var(--card-shadow);
        border: 1px solid #F1F5F9;
        display: flex;
        flex-direction: column;
        transition: all 0.3s ease;
    }

    .course-card-premium:hover {
        transform: translateY(-6px);
        box-shadow: 0 15px 35px rgba(0,0,0,0.06);
    }

    .thumb-wrap {
        height: 180px;
        background: #F8FAFC;
        position: relative;
    }

    .thumb-wrap img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .premium-badge {
        position: absolute;
        top: 1rem;
        right: 1rem;
        background: linear-gradient(135deg, #F59E0B, #D97706);
        color: white;
        padding: 0.35rem 0.75rem;
        border-radius: 8px;
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        box-shadow: 0 4px 8px rgba(217, 119, 6, 0.2);
    }

    .card-content {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        flex: 1;
    }

    .course-type {
        font-size: 0.7rem;
        font-weight: 800;
        color: #6366F1;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .card-content h3 {
        font-size: 1.25rem;
        font-weight: 800;
        color: #1E293B;
        margin: 0;
        line-height: 1.3;
    }

    .card-content p {
        font-size: 0.9rem;
        color: #64748B;
        margin: 0;
        line-height: 1.5;
    }

    .tech-stack {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: auto;
    }

    .tech-tag {
        background: #F1F5F9;
        color: #475569;
        padding: 0.25rem 0.65rem;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 700;
    }

    .card-footer {
        padding: 1.25rem 1.5rem;
        border-top: 1px solid #F1F5F9;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .price-tag { font-weight: 800; color: #1E293B; font-size: 1.1rem; }
    .price-tag.free { color: #10B981; }

    .action-group { display: flex; gap: 0.5rem; }

    .btn-circle {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        border: 1px solid #E2E8F0;
        background: white;
        color: #94A3B8;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
    }

    .btn-circle:hover { color: #0073ff; border-color: #0073ff; }

    /* LOADING */
    .loading-state {
        grid-column: 1 / -1;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 4rem;
        color: #94A3B8;
        gap: 1rem;
    }

    .spinner {
        width: 32px;
        height: 32px;
        border: 3px solid #F1F5F9;
        border-top-color: #0073ff;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    /* MODAL */
    .modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        backdrop-filter: blur(4px);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 2000;
    }
    .modal-card {
        background: white;
        padding: 3rem;
        border-radius: 24px;
        max-width: 550px;
        width: 90%;
        text-align: center;
    }
    .btn-close-modal {
        background: #0073ff;
        color: white;
        border: none;
        padding: 0.85rem 2rem;
        border-radius: 12px;
        font-weight: 700;
        margin-top: 1.5rem;
        cursor: pointer;
    }
</style>

<script>
    import { authManager } from '../../utils/auth';
    const auth = authManager;

    let allCourses = [];

    async function fetchData() {
        try {
            const data = await auth.get('courses');
            allCourses = data || [];
            
            // Mock if empty
            if (allCourses.length === 0) {
                allCourses = [
                    { title: 'Intro a la Web3 con Solidity', description: 'Fundamentos de smart contracts y dApps.', specialty_name: 'Blockchain', price: 49.99, is_premium: true, image: 'https://images.unsplash.com/photo-1639762681485-074b7f938ba0?auto=format&fit=crop&q=80&w=400' },
                    { title: 'Arquitectura de Microservicios', description: 'Escalamiento de aplicaciones con Docker y K8s.', specialty_name: 'Back-end', price: 0, is_premium: false, image: 'https://images.unsplash.com/photo-1558494949-ef010cbdcc51?auto=format&fit=crop&q=80&w=400' },
                    { title: 'UX/UI Design System Pro', description: 'Crea sistemas de diseño escalables y modernos.', specialty_name: 'Design', price: 79.99, is_premium: true, image: 'https://images.unsplash.com/photo-1586717791821-3f44a563eb4c?auto=format&fit=crop&q=80&w=400' }
                ];
            }
            renderCourses(allCourses);
            updateCount(allCourses.length);
        } catch (error) {
            console.error('Error fetching courses:', error);
        }
    }

    function renderCourses(list) {
        const grid = document.getElementById('coursesGrid');
        if (!grid) return;

        grid.innerHTML = list.map(c => `
            <div class="course-card-premium">
                <div class="thumb-wrap">
                    <img src="${c.image || 'https://via.placeholder.com/400x200'}" alt="${c.title}">
                    ${c.is_premium ? '<span class="premium-badge">PREMIUM</span>' : ''}
                </div>
                <div class="card-content">
                    <span class="course-type">${c.specialty_name || 'Especialidad'}</span>
                    <h3>${c.title}</h3>
                    <p>${c.description || 'Sin descripción disponible.'}</p>
                    <div class="tech-stack">
                        <span class="tech-tag">Next.js</span>
                        <span class="tech-tag">Tailwind</span>
                    </div>
                </div>
                <div class="card-footer">
                    <div class="price-tag ${c.price === 0 ? 'free' : ''}">
                        ${c.price === 0 ? 'GRATIS' : `$${c.price}`}
                    </div>
                    <div class="action-group">
                        <button class="btn-circle"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" /><path fill-rule="evenodd" d="M1.323 11.447C2.811 6.976 7.028 3.75 12.001 3.75c4.97 0 9.185 3.223 10.675 7.69.12.362.12.752 0 1.113-1.487 4.471-5.705 7.697-10.677 7.697-4.97 0-9.186-3.223-10.675-7.69a1.762 1.762 0 0 1 0-1.113ZM17.25 12a5.25 5.25 0 1 1-10.5 0 5.25 5.25 0 0 1 10.5 0Z" clip-rule="evenodd" /></svg></button>
                        <button class="btn-circle"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M21.731 2.269a2.625 2.625 0 0 0-3.712 0l-1.157 1.157 3.712 3.712 1.157-1.157a2.625 2.625 0 0 0 0-3.712ZM19.513 8.199l-3.712-3.712-12.15 12.15a5.25 5.25 0 0 0-1.32 2.214l-.8 2.685a.75.75 0 0 0 .933.933l2.685-.8a5.25 5.25 0 0 0 2.214-1.32L19.513 8.199Z" /></svg></button>
                        <button class="btn-circle"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M16.5 4.478v.227a48.816 48.816 0 0 1 3.878.512.75.75 0 1 1-.256 1.478l-.209-.035-1.005 13.07a3 3 0 0 1-2.991 2.77H8.084a3 3 0 0 1-2.991-2.77L4.087 6.66l-.209.035a.75.75 0 0 1-.256-1.478A48.567 48.567 0 0 1 7.5 4.705v-.227c0-1.564 1.213-2.9 2.816-2.951a52.662 52.662 0 0 1 3.369 0c1.603.051 2.815 1.387 2.815 2.951Zm-6.136-1.452a51.196 51.196 0 0 1 3.273 0C14.39 3.05 15 3.684 15 4.478v.113a49.488 49.488 0 0 0-6 0v-.113c0-.794.609-1.428 1.364-1.452Zm-.355 5.945a.75.75 0 1 0-1.5 0v8.25a.75.75 0 0 0 1.5 0v-8.25Zm2.25 0a.75.75 0 0 0-1.5 0v8.25a.75.75 0 0 0 1.5 0v-8.25Zm2.25 0a.75.75 0 1 0-1.5 0v8.25a.75.75 0 0 0 1.5 0v-8.25Z" clip-rule="evenodd" /></svg></button>
                    </div>
                </div>
            </div>
        `).join('');
    }

    function updateCount(n) {
        const el = document.getElementById('coursesTotalCount');
        if (el) el.textContent = `${n} cursos en la plataforma`;
    }

    document.getElementById('courseSearch')?.addEventListener('input', (e) => {
        const term = (e.target as HTMLInputElement).value.toLowerCase();
        renderCourses(allCourses.filter(c => 
            c.title.toLowerCase().includes(term) || 
            (c.specialty_name || '').toLowerCase().includes(term)
        ));
    });

    fetchData();
</script>

