---
// AdminHeader.astro
interface Props {
    title: string;
    subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<header class="admin-header">
    <div class="header-breadcrumb">
        <h1 class="header-title">{title}</h1>
        {subtitle && <p class="header-subtitle">{subtitle}</p>}
    </div>

    <div class="header-actions">
        <button class="action-btn-circle">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path fill-rule="evenodd" d="M5.25 9a6.75 6.75 0 0 1 13.5 0v.75c0 2.123.8 4.057 2.118 5.52a.75.75 0 0 1-.297 1.206c-1.544.57-3.16.99-4.831 1.243a3.75 3.75 0 1 1-7.48 0 24.585 24.585 0 0 1-4.831-1.244.75.75 0 0 1-.298-1.205A8.217 8.217 0 0 0 5.25 9.75V9Zm4.502 8.9a2.25 2.25 0 1 0 4.496 0 25.057 25.057 0 0 1-4.496 0Z" clip-rule="evenodd" /></svg>
            <span class="notification-dot"></span>
        </button>
        <div class="header-user-profile">
            <div class="avatar-circle" id="headerAvatarContainer">
                <span id="headerInitial">CR</span>
            </div>
            <span class="header-user-name" id="userNameHeader">Carlos</span>
        </div>
    </div>
</header>

<style>
    .admin-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid #E2E8F0;
    }

    .header-breadcrumb {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .header-title {
        font-size: 1.1rem;
        font-weight: 700;
        margin: 0;
        color: #0F172A;
    }

    .header-subtitle {
        font-size: 0.85rem;
        font-weight: 500;
        color: #94A3B8;
        margin: 0;
    }

    .header-actions {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .action-btn-circle {
        position: relative;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        background: white;
        border: 1px solid #E2E8F0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #64748B;
        cursor: pointer;
        transition: all 0.2s;
    }

    .action-btn-circle svg {
        width: 18px;
        height: 18px;
    }

    .action-btn-circle:hover {
        background: #F8FAFC;
        color: #0073ff;
    }

    .notification-dot {
        position: absolute;
        top: 10px;
        right: 12px;
        width: 8px;
        height: 8px;
        background: #EF4444;
        border: 2px solid white;
        border-radius: 50%;
    }

    .header-user-profile {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
        padding: 0.25rem 0.5rem;
        border-radius: 8px;
        transition: background 0.2s;
    }
    .header-user-profile:hover {
        background: #F1F5F9;
    }

    .avatar-circle {
        width: 28px;
        height: 28px;
        background: #3b82f6;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
        font-size: 0.75rem;
        overflow: hidden;
    }
    .avatar-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .header-user-name {
        font-size: 0.85rem;
        font-weight: 500;
        color: #475569;
    }
</style>

<script>
    import { authManager } from '../../utils/auth.js';
    const auth = authManager;
    const user = auth.getUser();
    if (user) {
        if (document.getElementById('userNameHeader')) {
            document.getElementById('userNameHeader').textContent = (user.name_user || 'Admin').split(' ')[0];
        }
        
        const avatarContainer = document.getElementById('headerAvatarContainer');
        const photoUrl = user.photo_url || `https://api.dicebear.com/7.x/avataaars/svg?seed=${encodeURIComponent(user.name_user || 'admin')}&backgroundColor=b6e3f4`;
        
        if (avatarContainer) {
            avatarContainer.innerHTML = `<img src="${photoUrl}" alt="Avatar" class="avatar-img" />`;
        }
    }
</script>

