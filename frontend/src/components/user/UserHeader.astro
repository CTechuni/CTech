---
// UserHeader.astro
interface Props {
    title: string;
    subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<header class="user-header">
    <div class="header-info">
        <h1>{title}</h1>
        {subtitle && <p class="subtitle">{subtitle}</p>}
    </div>

    <div class="header-actions">
        <div class="search-bar glass-input">
            <i class="fas fa-search"></i>
            <input type="text" placeholder="Buscar cursos, eventos..." />
        </div>
        <div class="user-profile">
            <div class="user-info">
                <span id="userName">User Name</span>
                <span class="role-tag">Estudiante CTech</span>
            </div>
            <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=user" alt="avatar" />
        </div>
    </div>
</header>

<style>
    .user-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2.8rem;
        padding: 0.5rem 0;
    }

    .header-info h1 {
        font-size: 2.4rem;
        font-weight: 900;
        margin: 0;
        background: linear-gradient(135deg, #fff 0%, #f59e0b 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        letter-spacing: -0.04em;
    }

    .subtitle {
        color: rgba(255, 255, 255, 0.4);
        margin: 0.5rem 0 0;
        font-size: 1.1rem;
        font-weight: 400;
    }

    .header-actions {
        display: flex;
        align-items: center;
        gap: 3rem;
    }

    .glass-input {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        padding: 0.6rem 1.2rem;
        display: flex;
        align-items: center;
        gap: 0.8rem;
        color: rgba(255, 255, 255, 0.6);
        width: 300px;
        transition: all 0.3s ease;
    }

    .glass-input:focus-within {
        background: rgba(255, 255, 255, 0.08);
        border-color: rgba(245, 158, 11, 0.5);
        box-shadow: 0 0 20px rgba(245, 158, 11, 0.1);
    }

    .glass-input input {
        background: transparent;
        border: none;
        color: white;
        width: 100%;
        outline: none;
        font-size: 0.9rem;
    }

    .user-profile {
        display: flex;
        align-items: center;
        gap: 1.2rem;
        background: rgba(255, 255, 255, 0.05);
        padding: 0.8rem 1.4rem;
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.06);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
    }

    .user-profile:hover {
        background: rgba(255, 255, 255, 0.09);
        border-color: rgba(245, 158, 11, 0.4);
        transform: translateY(-3px) scale(1.02);
    }

    .user-info {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
    }

    .user-info #userName { font-weight: 800; font-size: 1.05rem; color: white; }
    .role-tag { font-size: 0.75rem; color: #f59e0b; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; }

    .user-profile img {
        width: 48px;
        height: 48px;
        border-radius: 16px;
        border: 2px solid rgba(245, 158, 11, 0.3);
    }
</style>

<script>
    /* ⚠️ BYPASS TEMPORAL - SOLO SIMULACRO VISUAL. Reactivar antes de producción.
