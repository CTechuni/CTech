---
// UserSidebar.astro
const menuItems = [
    { icon: 'fas fa-tachometer-alt', label: 'Inicio', path: '/user' },
    { icon: 'fas fa-search', label: 'Explorar Cursos', path: '/user/courses' },
    { icon: 'fas fa-calendar-alt', label: 'Calendario', path: '/user/calendar' },
    { icon: 'fas fa-users', label: 'Mi Comunidad', path: '/user/community' },
    { icon: 'fas fa-id-card', label: 'Mi Perfil', path: '/user/profile' },
    { icon: 'fas fa-sliders-h', label: 'Ajustes', path: '/user/settings' },
];
---

<aside class="user-sidebar">
    <div class="sidebar-logo">
        <img src="/logo-ctech.png" alt="CTech" />
        <span>CTech App</span>
    </div>

    <nav class="sidebar-nav">
        {menuItems.map(item => (
            <a href={item.path} class="nav-item">
                <i class={item.icon}></i>
                <span>{item.label}</span>
            </a>
        ))}
    </nav>

    <div class="sidebar-footer">
        <button id="logoutBtn" class="nav-item logout">
            <i class="fas fa-sign-out-alt"></i>
            <span>Cerrar Sesión</span>
        </button>
    </div>
</aside>

<style>
    .user-sidebar {
        width: 280px;
        height: 100vh;
        position: fixed;
        left: 0;
        top: 0;
        border-right: 1px solid rgba(255, 255, 255, 0.1);
        display: flex;
        flex-direction: column;
        padding: 2.22rem 1.66rem;
        z-index: 1000;
        box-shadow: 10px 0 50px rgba(0, 0, 0, 0.4);
    }

    

    .sidebar-logo {
        display: flex;
        align-items: center;
        gap: 1.3rem;
        margin-bottom: 3.6rem;
        padding-left: 0.7rem;
    }

    .sidebar-logo img { width: 44px; filter: drop-shadow(0 0 12px rgba(245, 158, 11, 0.4)); }
    .sidebar-logo span { 
        font-weight: 900; 
        font-size: 1.4rem;
        background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        letter-spacing: -0.04em;
    }

    .sidebar-nav { flex: 1; }

    .nav-item {
        display: flex;
        align-items: center;
        gap: 1.2rem;
        padding: 1.1rem 1.4rem;
        color: rgba(255, 255, 255, 0.5);
        text-decoration: none;
        border-radius: 16px;
        margin-bottom: 0.8rem;
        transition: all 0.4s ease-in-out;
    }

    .nav-item:hover {
        background: rgba(245, 158, 11, 0.12);
        color: #fbbf24;
        transform: rotateX(10deg) translateX(6px);
    }

    .nav-item.active {
        background: linear-gradient(135deg, rgba(245, 158, 11, 0.3) 0%, rgba(217, 119, 6, 0.25) 100%);
        color: white;
        border: 1px solid rgba(245, 158, 11, 0.4);
        box-shadow: 0 8px 25px rgba(245, 158, 11, 0.15);
    }

    .nav-item i { width: 26px; font-size: 1.3rem; }

    .logout {
        width: 100%;
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 1rem 1.4rem;
        font-size: 1rem;
        color: #fca5a5 !important;
        justify-content: flex-start;
    }
</style>

<script>
    /* ⚠️ BYPASS TEMPORAL - SOLO SIMULACRO VISUAL. Reactivar antes de producción.
    import { AuthManager, authManager } from "../../utils/auth.js";

    document.getElementById('logoutBtn')?.addEventListener('click', () => {
        const auth = authManager;
        auth.logout();
        window.location.href = '/login';
    });
    */

    // Logout estático para simulacro
    document.getElementById('logoutBtn')?.addEventListener('click', () => {
        console.info('[BYPASS VISUAL] Logout deshabilitado durante simulacro.');
        window.location.href = '/';
    });

    const currentPath = window.location.pathname;
    const urlParams = new URLSearchParams(window.location.search);
    const userId = urlParams.get('id');

    document.querySelectorAll('.nav-item').forEach(link => {
        // Persistir ID en los enlaces si existe
        if (userId && link.tagName === 'A') {
            const href = link.getAttribute('href');
            if (href && !href.startsWith('http') && !href.includes('id=')) {
                link.setAttribute('href', `${href}${href.includes('?') ? '&' : '?'}id=${userId}`);
            }
        }

        // Marcar activo
        if (link.getAttribute('href')?.split('?')[0] === currentPath) {
            link.classList.add('active');
        }
    });
</script>

