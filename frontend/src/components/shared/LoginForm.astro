---
// Astro component script (if needed)
---

<form class="login-form" id="loginForm" method="POST">
    <div class="form-group">
        <label for="email">Correo electrónico</label>
        <input 
            type="email" 
            id="email" 
            name="email" 
            placeholder="tu@email.com"
        >
        <span class="error-message" id="emailError"></span>
    </div>

    <div class="form-group">
        <label for="password">Contraseña</label>
        <input 
            type="password" 
            id="password" 
            name="password" 
            placeholder="••••••"
        >
        <span class="error-message" id="passwordError"></span>
    </div>

    <div class="form-options">
        <label class="checkbox-container">
            <input type="checkbox" name="remember">
            <span class="checkmark"></span>
            Recordarme
        </label>
        <a href="#" class="forgot-password">¿Olvidaste tu contraseña?</a>
    </div>

    <button type="submit" class="login-btn">
        Iniciar Sesión
    </button>



    <div class="signup-link">
        <p>¿No tienes cuenta? <a href="#" onclick="window.closeModal('loginModal'); window.openModal('signupModal')">Regístrate aquí</a></p>
    </div>
</form>


<style>
    .login-form {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }

    .form-group label {
        font-weight: 500;
        color: var(--color-primary-dark);
        font-size: 0.9rem;
        margin: 0 1rem 0 1rem;
    }

    .form-group input {
        padding: 0.6rem 1rem;
        border: 1px solid #dbdee1;
        border-radius: 25px;
        font-size: 0.9rem;
        transition: border-color 0.3s ease;
    }

    .form-group input:focus {
        outline: none;
        border-color: #06060640;
    }

    .form-group input.error {
        border-color: #ef4444;
        background-color: #fef2f2;
    }

    .error-message {
        color: #ef4444;
        font-size: 0.8rem;
        margin-left: 1rem;
        margin-top: -0.1rem;
        display: none;
    }

    .error-message.visible {
        display: block;
    }

    .form-options {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.9rem;
    }

    .checkbox-container {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
        font-size: 0.9rem;
        color: #666;
    }

    .checkbox-container input[type="checkbox"] {
        width: auto;
        margin: 0;
    }

    .forgot-password {
        color: var(--color-azure-radiant);
        text-decoration: none;
        font-size: 0.9rem;
    }

    .forgot-password:hover {
        text-decoration: underline;
    }

    .login-btn {
        padding: 0.6rem 1.5rem;
        background-color: var(--color-azure-radiant);
        color: var(--color-white);
        border: none;
        border-radius: 25px;
        font-size: 1rem;
        font-weight: 500;
        cursor: pointer;
        transition: background-color 0.3s ease;
        text-align: center;
        display: block;
        width: 100%;
        box-sizing: border-box;
    }

    .login-btn:hover {
        background-color: var(--color-primary);
    }

    .login-btn:active {
        background-color: var(--color-blue-grey);
    }

    .login-btn:disabled {
        background-color: #6c757d;
        cursor: not-allowed;
    }

    .signup-link {
        text-align: center;
        font-size: 0.9rem;
        color: var(--color-primary-dark);
    }

    .signup-link a {
        color: var(--color-azure-radiant);
        text-decoration: none;
        font-weight: 500;
    }

    .signup-link a:hover {
        text-decoration: underline;
    }

</style>

<script type="module">
    import { authManager } from '../../utils/auth.js';

    // Cerrar modal (complemento de openModal)
    function closeModal(modalId) {
        const modal = document.getElementById(modalId);
        if (modal) {
            modal.style.display = 'none';
            modal.classList.remove('show');
        }
    }

    // Función para abrir modal (se define globalmente)
    window.openModal = function (modalId) {
        const modal = document.getElementById(modalId);
        if (modal) {
            modal.style.display = 'block';
            modal.classList.add('show');
        }
    };

    // Manejo del formulario de login
    const loginForm = document.getElementById('loginForm');
    if (loginForm) {
        // Limpiar errores al escribir
        function clearError(inputId, errorId) {
            const input = document.getElementById(inputId);
            const error = document.getElementById(errorId);
            if(input) input.classList.remove('error');
            if(error) {
                error.textContent = '';
                error.classList.remove('visible');
            }
        }

        document.getElementById('email')?.addEventListener('input', () => clearError('email', 'emailError'));
        document.getElementById('password')?.addEventListener('input', () => clearError('password', 'passwordError'));

        loginForm.addEventListener('submit', async function (e) {
            e.preventDefault(); // CRITICAL: Stop the page from refreshing and showing credentials in URL

            const emailInput = document.getElementById('email');
            const passwordInput = document.getElementById('password');
            const emailError = document.getElementById('emailError');
            const passwordError = document.getElementById('passwordError');
            
            let hasErrors = false;

            const email = String(emailInput.value || '').trim();
            const password = String(passwordInput.value || '');

            // Validations...
            if (!email) {
                emailInput.classList.add('error');
                emailError.textContent = 'El correo es obligatorio';
                emailError.classList.add('visible');
                hasErrors = true;
            } else if (!/^\S+@\S+\.\S+$/.test(email)) {
                emailInput.classList.add('error');
                emailError.textContent = 'Correo inválido';
                emailError.classList.add('visible');
                hasErrors = true;
            }
            if (!password) {
                passwordInput.classList.add('error');
                passwordError.textContent = 'La contraseña es obligatoria';
                passwordError.classList.add('visible');
                hasErrors = true;
            }

            if (hasErrors) return;

            // Submit Button status
            const submitBtn = this.querySelector('.login-btn');
            const originalText = submitBtn ? submitBtn.textContent : '';
            if (submitBtn) {
                submitBtn.textContent = 'Iniciando sesión...';
                submitBtn.disabled = true;
            }

            try {
                const result = await authManager.login(email, password, false);

                console.debug('login result', result);

                // Update UI first
                updateAuthUI(result.user);
                
                // REDIRECTION LOGIC (Strictly based on role)
                const role = String(result.user?.role || '').toLowerCase().trim();
                if (!role) {
                    // if the server didn't include a role, cart and surface
                    throw new Error('No se pudo determinar el rol en la respuesta del servidor');
                }
                let redirectPath = '/user'; // Default
                
                if (role === 'admin') {
                    redirectPath = '/admin';
                } else if (role === 'mentor') {
                    redirectPath = '/mentor';
                } else if (role === 'leader' || role === 'lider') {
                    redirectPath = '/leader';
                }
                
                // Close modal and redirect
                closeModal('loginModal');
                window.location.href = redirectPath;

            } catch (error) {
                console.error('login failed', error);
                passwordError.textContent = error.message || 'Credenciales incorrectas';
                passwordError.classList.add('visible');
            } finally {
                if (submitBtn) {
                    submitBtn.textContent = originalText;
                    submitBtn.disabled = false;
                }
            }
        });
    }

    // Función para actualizar la UI después del login
    function updateAuthUI(user) {
        // En el estado original sólo mostraba un log o ajustaba botones.
    }

    // Función para logout
    window.logout = async function () {
        try {
            if (!authManager || typeof authManager.logout !== 'function') {
                throw new Error('El gestor de autenticación no está disponible.');
            }
            await authManager.logout();
        } catch (error) {
            console.error('Error al cerrar sesión:', error);
            alert('Error al cerrar sesión: ' + (error?.message || error));
        }
    };
</script>
